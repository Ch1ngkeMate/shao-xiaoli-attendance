# 复制为 .env 或仅在服务器/宝塔「环境变量」中填写（勿把真实 .env 提交到 Git）

# 必填：MySQL 连接串（密码中的特殊字符需 URL 编码，如 @ → %40）
# 示例：mysql://root:密码@127.0.0.1:3306/shaoxiaoli_attendance
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE"

# 必填：登录会话签名密钥（生产环境请使用 openssl rand -base64 32 生成随机串）
AUTH_SECRET="请替换为足够长的随机字符串"

# 可选：Vercel Blob 图床；不填则走本地上传逻辑
# BLOB_READ_WRITE_TOKEN=

# 可选：仅 scripts/init-admin.ts 首次建管理员时用
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_PASSWORD=
# INIT_ADMIN_DISPLAY_NAME=系统管理员

# 可选：管理员「全员重置密码」功能使用的初始密码
# ADMIN_RESET_PASSWORD=

# 微信小程序（备案通过后，在微信公众平台获取）
WX_APPID="你的小程序AppID"
WX_SECRET="你的小程序AppSecret"

# 微信订阅消息模板ID（在微信公众平台「功能 → 订阅消息」选用后获得）
WX_TASK_TMPL_ID="任务通知模板ID"
WX_MEETING_TMPL_ID="会议通知模板ID"
