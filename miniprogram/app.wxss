/* 全局样式 - 对标 Ant Design 蓝色主题 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 主色调 */
.primary { color: #1677ff; }
.primary-bg { background-color: #1677ff; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn-primary {
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 18rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-primary:active { opacity: 0.8; }

.btn-ghost {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
  border-radius: 10rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 18rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 提示文字 */
.hint {
  color: #999;
  font-size: 24rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
}
.tag-blue { background: #e6f4ff; color: #1677ff; }
.tag-green { background: #f6ffed; color: #52c41a; }
.tag-orange { background: #fff7e6; color: #fa8c16; }
.tag-red { background: #fff1f0; color: #ff4d4f; }
.tag-gray { background: #f5f5f5; color: #999; }

/* 分割线 */
.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-1 { flex: 1; }

/* 间距 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-24 { padding: 24rpx; }

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-bar input {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  background: #1677ff;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  z-index: 100;
}
