/* 全局样式 — Animal Island 动森主题 */

@import "./anisland-theme/theme.wxss";

page {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--color-text);
  background: var(--color-bg);
  line-height: 1.57;
  box-sizing: border-box;
}

/* ===== 卡片 ===== */
.card {
  background: var(--color-bg-container);
  border-radius: var(--border-radius-base);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
  border: 3rpx solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}
.card:active { box-shadow: var(--shadow-base); }

.card-sm {
  background: var(--color-bg-container);
  border-radius: var(--border-radius-sm);
  padding: var(--spacing-sm);
  margin: var(--spacing-xs) var(--spacing-md);
  border: 3rpx solid var(--color-border-light);
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-sm);
  line-height: 1.4;
  white-space: nowrap;
  border: 2rpx solid transparent;
}

.tag-blue   { background: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary); }
.tag-green  { background: #e8f5e0; color: var(--color-success); border-color: var(--color-success); }
.tag-red    { background: #fde8e8; color: var(--color-error); border-color: var(--color-error); }
.tag-orange { background: #fef4e6; color: #d4730b; border-color: var(--color-warning); }
.tag-gold   { background: #fef7e0; color: #b8860b; border-color: var(--color-warning); }
.tag-gray   { background: var(--color-bg-disabled); color: var(--color-text-disabled); border-color: var(--color-border); }
.tag-geekblue { background: #edf0fc; color: #3d5cc4; border-color: #8fa0e0; }
.tag-magenta { background: #fdf0f5; color: #c63678; border-color: #e892b9; }
.tag-volcano { background: #fef2e8; color: #c44a1a; border-color: #e8956e; }

/* ===== 按钮 ===== */
.btn-primary {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  background: var(--color-primary); color: #fff;
  border: none; border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 600;
  box-shadow: var(--shadow-sm);
  transition: all var(--motion-fast) var(--motion-ease);
}
.btn-primary:active {
  background: var(--color-primary-active);
  box-shadow: var(--shadow-base);
  transform: scale(0.97);
}
.btn-primary[disabled] { opacity: 0.5; }

.btn-danger {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  background: var(--color-error); color: #fff;
  border: none; border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 600;
  box-shadow: var(--shadow-sm);
}
.btn-danger:active { background: var(--color-error-active); transform: scale(0.97); }

.btn-dashed {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  background: var(--color-bg-container); color: var(--color-primary);
  border: 3rpx dashed var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 600;
}
.btn-dashed:active { border-color: var(--color-primary); }

.btn-ghost {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  background: var(--color-bg-container); color: var(--color-text);
  border: 3rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 600;
}
.btn-ghost:active { border-color: var(--color-primary); color: var(--color-primary); }

.btn-link {
  display: inline-flex; align-items: center;
  padding: 8rpx 0;
  background: none; color: var(--color-primary);
  border: none;
  font-size: var(--font-size-base);
}

/* ===== 输入框 ===== */
.input {
  height: 72rpx; padding: 0 20rpx;
  background: var(--color-bg-container); color: var(--color-text);
  border: 3rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); width: 100%; box-sizing: border-box;
  transition: border-color var(--motion-fast);
}
.input:focus { border-color: var(--color-primary); }

.textarea {
  width: 100%; min-height: 160rpx; padding: 16rpx 20rpx;
  background: var(--color-bg-container);
  border: 3rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); box-sizing: border-box;
}
.textarea:focus { border-color: var(--color-primary); }

/* ===== 布局工具 ===== */
.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: var(--spacing-sm); }
.gap-16 { gap: var(--spacing-md); }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: var(--spacing-sm); }
.mt-16 { margin-top: var(--spacing-md); }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: var(--spacing-md); }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

.hint { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.primary { color: var(--color-primary); }
.error { color: var(--color-error); }

/* ===== 空状态 ===== */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 96rpx 32rpx; color: var(--color-text-secondary); font-size: var(--font-size-base);
}
.empty-icon { font-size: 80rpx; margin-bottom: var(--spacing-md); opacity: 0.5; }

/* ===== 加载 ===== */
.load-more { text-align: center; padding: 32rpx; font-size: var(--font-size-sm); color: var(--color-text-secondary); }

/* ===== 卡片标题 ===== */
.card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--spacing-md);
}

/* ===== 头像 ===== */
.avatar {
  width: 72rpx; height: 72rpx;
  border-radius: var(--border-radius-round);
  border: 3rpx solid var(--color-primary);
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary);
  font-weight: 700;
  font-size: var(--font-size-base);
  overflow: hidden;
}
.avatar-lg {
  width: 96rpx; height: 96rpx;
  font-size: var(--font-size-lg);
}
.avatar-sm {
  width: 56rpx; height: 56rpx;
  font-size: var(--font-size-sm);
}
