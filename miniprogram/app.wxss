/* 全局样式 — Animal Island 动森主题 v2 */
/* Pixel-perfect from SKILL.md */

@import "./anisland-theme/theme.wxss";

page {
  font-family: var(--animal-font);
  font-size: var(--font-size-base);
  color: var(--color-text-body);
  background: var(--color-bg);
  line-height: 1.57;
  font-weight: 500;
  letter-spacing: 0.01em;
  box-sizing: border-box;
}

/* ============================================
 * 卡片（NookPhone 奶油纸质感）
 * ============================================ */
.card {
  background: var(--color-bg-content);
  border-radius: 40rpx;                     /* 20px */
  padding: 32rpx 48rpx;                    /* 16px 24px */
  margin: 16rpx 32rpx;
  color: var(--color-text-body);
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(107, 92, 67, 0.42);
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(-8rpx);             /* -4px hover float */
}

.card-sm {
  background: var(--color-bg-content);
  border-radius: 36rpx;                     /* 18px */
  padding: 24rpx 32rpx;
  margin: 12rpx 32rpx;
  box-shadow: 0 6rpx 14rpx rgba(107, 92, 67, 0.35);
}

/* ============================================
 * 3D Pill 按钮（默认样式，全站使用）
 * ============================================ */
/* 主按钮 */
.btn-primary {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx;                            /* 45px */
  padding: 0 40rpx;
  font-size: 28rpx;                        /* 14px */
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1;
  border-radius: 100rpx;                   /* 50px pill */
  border: 2px solid var(--color-bg);
  background: var(--color-bg);             /* 奶油白 */
  color: var(--color-text);               /* 暖棕 */
  box-shadow: 0 10rpx 0 0 var(--color-shadow-btn);
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-primary:active {
  transform: translateY(4rpx);             /* 2px down press */
  box-shadow: 0 2rpx 0 0 var(--color-shadow-btn);
}
.btn-primary:focus-visible {
  outline: 4rpx solid var(--color-primary);
  outline-offset: 4rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
  transform: none !important;
  box-shadow: none !important;
}

/* 危险按钮 */
.btn-danger {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-error);
  color: #fff;
  box-shadow: 0 10rpx 0 0 var(--color-error-active);
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-danger:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 var(--color-error-active);
}

/* 描边按钮 */
.btn-ghost {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-bg-content);
  color: var(--color-text-body);
  border: 5rpx solid var(--color-border-light);
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-ghost:active {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

/* 虚线按钮 */
.btn-dashed {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  border-radius: 100rpx;
  background: var(--color-bg-content);
  color: var(--color-primary);
  border: 5rpx dashed var(--color-border);
}

/* 文字链接按钮 */
.btn-link {
  display: inline-flex; align-items: center;
  padding: 8rpx 0;
  background: none; color: var(--color-primary);
  border: none;
  font-size: var(--font-size-base); font-weight: 600;
}

/* ============================================
 * 3D Pill 输入框
 * ============================================ */
.input {
  height: 80rpx;                            /* 40px */
  padding: 0 36rpx;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 0.01em;
  color: var(--color-text-body);
  background: var(--color-bg-input);
  border: 5rpx solid var(--color-border-light);
  border-radius: 100rpx;                    /* 50px pill */
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  box-sizing: border-box;
  width: 100%;
  transition: all var(--motion-base) var(--motion-ease);
}
.input::placeholder {
  color: var(--color-text-disabled);
  font-weight: 400;
}
.input:focus {
  border-color: var(--color-focus-yellow) !important;
  box-shadow: 0 6rpx 0 0 var(--color-focus-yellow-d),
              0 0 0 6rpx rgba(255, 204, 0, 0.15);
}
.input[disabled] {
  background: var(--color-bg-input-dis);
  border-color: var(--color-shadow-input);
  box-shadow: none;
  opacity: 0.6;
}

.textarea {
  width: 100%; min-height: 160rpx;
  padding: 24rpx 36rpx;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 0.01em;
  color: var(--color-text-body);
  background: var(--color-bg-input);
  border: 5rpx solid var(--color-border-light);
  border-radius: 40rpx;                     /* 20px card-like */
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  box-sizing: border-box;
  transition: all var(--motion-base) var(--motion-ease);
}
.textarea:focus {
  border-color: var(--color-focus-yellow) !important;
  box-shadow: 0 6rpx 0 0 var(--color-focus-yellow-d),
              0 0 0 6rpx rgba(255, 204, 0, 0.15);
}

/* ============================================
 * 标签
 * ============================================ */
.tag {
  display: inline-flex; align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;                     /* 10px */
  font-size: var(--font-size-xs);
  font-weight: 500;
  border: 3rpx solid transparent;
  letter-spacing: 0.01em;
}
.tag-blue   { background: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary); }
.tag-green  { background: #e8f5e0; color: var(--color-success); border-color: var(--color-success); }
.tag-red    { background: #fde8e8; color: var(--color-error); border-color: var(--color-error); }
.tag-orange { background: #fef4e6; color: #d4730b; border-color: var(--color-warning); }
.tag-gold   { background: #fef7e0; color: #b8860b; border-color: var(--color-warning); }
.tag-gray   { background: var(--color-bg-disabled); color: var(--color-text-disabled); border-color: var(--color-border-light); }
.tag-geekblue { background: #edf0fc; color: #3d5cc4; border-color: #8fa0e0; }
.tag-magenta { background: #fdf0f5; color: #c63678; border-color: #e892b9; }
.tag-volcano { background: #fef2e8; color: #c44a1a; border-color: #e8956e; }

/* ============================================
 * 工具类
 * ============================================ */
.card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}
.hint { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.primary { color: var(--color-primary); }
.error { color: var(--color-error); }

.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 16rpx; }
.gap-16 { gap: 24rpx; }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 16rpx; }
.mt-16 { margin-top: 24rpx; }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 24rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

/* 空状态 */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 96rpx 32rpx; color: var(--color-text-muted); font-size: var(--font-size-base);
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.5; }
.load-more { text-align: center; padding: 32rpx; font-size: var(--font-size-sm); color: var(--color-text-secondary); }

/* 头像 */
.avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  border: 5rpx solid var(--color-primary);
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary);
  font-weight: 700; font-size: var(--font-size-base);
  overflow: hidden;
}
.avatar-lg { width: 96rpx; height: 96rpx; font-size: var(--font-size-lg); }
.avatar-sm { width: 56rpx; height: 56rpx; font-size: var(--font-size-sm); }
