/* 全局样式 — 复刻 Web 端 Ant Design 6 设计系统 */

page {
  --color-primary: #1677ff;
  --color-primary-bg: #e6f4ff;
  --color-primary-hover: #4096ff;
  --color-primary-active: #0958d9;
  --color-success: #52c41a;
  --color-warning: #faad14;
  --color-error: #ff4d4f;
  --color-text: rgba(0, 0, 0, 0.88);
  --color-text-secondary: rgba(0, 0, 0, 0.65);
  --color-text-tertiary: rgba(0, 0, 0, 0.45);
  --color-border: #d9d9d9;
  --color-border-secondary: #f0f0f0;
  --color-split: rgba(0, 0, 0, 0.06);
  --color-bg-container: #ffffff;
  --color-bg-layout: #f5f5f5;
  --color-fill-alter: rgba(0, 0, 0, 0.02);

  --font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 40rpx;
  --font-size-h4: 40rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  --border-radius-sm: 8rpx;
  --border-radius: 12rpx;
  --border-radius-lg: 16rpx;
  --border-radius-xl: 20rpx;
  --border-radius-xxl: 28rpx;

  --shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);

  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--color-text);
  background: var(--color-bg-layout);
  line-height: 1.57;
  -webkit-font-smoothing: antialiased;
}

/* ===== 卡片 ===== */
.card {
  background: var(--color-bg-container);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
  border: 2rpx solid var(--color-border-secondary);
}

.card-sm {
  background: var(--color-bg-container);
  border-radius: var(--border-radius);
  padding: var(--spacing-sm);
  margin: var(--spacing-xs) var(--spacing-md);
  border: 2rpx solid var(--color-border-secondary);
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-sm);
  line-height: 1.4;
  white-space: nowrap;
}

.tag-blue   { background: #e6f4ff; color: #1677ff; border: 1rpx solid #91caff; }
.tag-green  { background: #f6ffed; color: #52c41a; border: 1rpx solid #b7eb8f; }
.tag-red    { background: #fff2f0; color: #ff4d4f; border: 1rpx solid #ffccc7; }
.tag-orange { background: #fff7e6; color: #fa8c16; border: 1rpx solid #ffd591; }
.tag-gold   { background: #fffbe6; color: #d48806; border: 1rpx solid #ffe58f; }
.tag-gray   { background: #fafafa; color: rgba(0,0,0,0.45); border: 1rpx solid #d9d9d9; }
.tag-geekblue { background: #f0f5ff; color: #2f54eb; border: 1rpx solid #adc6ff; }
.tag-magenta { background: #fff0f6; color: #eb2f96; border: 1rpx solid #ffadd2; }
.tag-volcano { background: #fff2e8; color: #d4380d; border: 1rpx solid #ffbb96; }

/* ===== 按钮 ===== */
.btn-primary {
  display: flex; align-items: center; justify-content: center;
  height: 64rpx; padding: 0 32rpx;
  background: var(--color-primary); color: #fff;
  border: none; border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 500;
}
.btn-primary:active { background: var(--color-primary-active); }
.btn-primary[disabled] { opacity: 0.5; }

.btn-danger {
  display: flex; align-items: center; justify-content: center;
  height: 64rpx; padding: 0 32rpx;
  background: var(--color-error); color: #fff;
  border: none; border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); font-weight: 500;
}

.btn-dashed {
  display: flex; align-items: center; justify-content: center;
  height: 64rpx; padding: 0 32rpx;
  background: #fff; color: var(--color-primary);
  border: 2rpx dashed var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base);
}

.btn-ghost {
  display: flex; align-items: center; justify-content: center;
  height: 64rpx; padding: 0 32rpx;
  background: #fff; color: var(--color-text);
  border: 2rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base);
}

.btn-link {
  display: inline-flex; align-items: center;
  padding: 8rpx 0;
  background: none; color: var(--color-primary);
  border: none;
  font-size: var(--font-size-base);
}

/* ===== 输入框 ===== */
.input {
  height: 64rpx; padding: 0 20rpx;
  background: var(--color-bg-container); color: var(--color-text);
  border: 2rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); width: 100%; box-sizing: border-box;
}
.input:focus { border-color: var(--color-primary); }

.textarea {
  width: 100%; min-height: 160rpx; padding: 16rpx 20rpx;
  background: var(--color-bg-container);
  border: 2rpx solid var(--color-border); border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base); box-sizing: border-box;
}

/* ===== 布局工具 ===== */
.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: var(--spacing-sm); }
.gap-16 { gap: var(--spacing-md); }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: var(--spacing-sm); }
.mt-16 { margin-top: var(--spacing-md); }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: var(--spacing-md); }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

.hint { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.primary { color: var(--color-primary); }
.error { color: var(--color-error); }

/* ===== 空状态 ===== */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 96rpx 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-base);
}
.empty-icon { font-size: 80rpx; margin-bottom: var(--spacing-md); opacity: 0.5; }

/* ===== 加载 ===== */
.load-more { text-align: center; padding: 32rpx; font-size: var(--font-size-sm); color: var(--color-text-tertiary); }
