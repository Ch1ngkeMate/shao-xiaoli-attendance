/* ============================================
 * 全局样式 — Animal Island 动森主题 v3
 * 像素级还原源码
 * ============================================ */

@import "./anisland-theme/theme.wxss";

page {
  font-family: var(--animal-font);
  font-size: var(--font-size-base);
  color: var(--color-text-body);
  background: var(--color-bg);
  line-height: 1.57;
  font-weight: 500;
  letter-spacing: 0.01em;
  box-sizing: border-box;
}

/* 背景纹理 — 模拟帆布触感 */
page::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image:
    radial-gradient(circle at 25% 25%, rgba(161, 140, 107, 0.06) 1rpx, transparent 1rpx),
    radial-gradient(circle at 75% 75%, rgba(161, 140, 107, 0.04) 1rpx, transparent 1rpx);
  background-size: 24rpx 24rpx, 20rpx 20rpx;
}

/* ============================================
 * 卡片（核心组件）
 * ============================================ */
.card {
  background: var(--color-bg-content);
  border-radius: 40rpx;
  padding: 32rpx 48rpx;
  margin: 16rpx 32rpx;
  color: #725d42;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(107, 92, 67, 0.42);  /* 官方 0 4px 10px rgba(107,92,67,0.42) */
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(-4rpx);
}

.card-sm {
  background: var(--color-bg-content);
  border-radius: 36rpx;
  padding: 24rpx 32rpx;
  margin: 12rpx 32rpx;
}

/* ============================================
 * 3D Pill 按钮（动森核心特征）
 * ============================================ */

/* 主按钮 — 奶油色+棕字+3D厚底阴影 */
.btn-primary {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx;                            /* 45px */
  padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;                    /* 50px pill */
  border: 2px solid #f8f8f0;
  background: #f8f8f0;                     /* 奶油白 */
  color: #794f27;                          /* 暖棕字 */
  box-shadow: 0 10rpx 0 0 #bdaea0;         /* 3D阴影 */
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 0 0 #bdaea0;
}
.btn-primary:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 #bdaea0;
}
.btn-primary:focus-visible {
  outline: 4rpx solid var(--color-primary);
  outline-offset: 4rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
  transform: none !important;
  box-shadow: none !important;
}

/* 危险按钮 — 红色+3D阴影 */
.btn-danger {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-error);
  color: #fff;
  box-shadow: 0 10rpx 0 0 var(--color-error-active);
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-danger:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 0 0 var(--color-error-active);
}
.btn-danger:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 var(--color-error-active);
}

/* 描边按钮 — 透明背景+虚线边框 */
.btn-dashed {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  border-radius: 100rpx;
  background: var(--color-bg-content);
  color: var(--color-text);
  border: 5rpx dashed var(--color-border);
}
.btn-dashed:active {
  border-style: solid;
  border-color: var(--color-primary);
  color: var(--color-primary);
}

/* 幽灵按钮 — 扁平无阴影 */
.btn-ghost {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  border-radius: 100rpx;
  background: transparent;
  color: var(--color-text);
  border: 5rpx solid var(--color-border);
  box-shadow: none;
}
.btn-ghost:active {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: rgba(25, 200, 185, 0.08);
}

/* 文字链接 */
.btn-link {
  display: inline-flex; align-items: center;
  padding: 8rpx 0;
  background: none; color: var(--color-primary);
  border: none;
  font-size: var(--font-size-base); font-weight: 600;
}
.btn-link:active {
  opacity: 0.85;
}

/* 弹窗确认按钮 — 游戏黄色（动森经典交互色）*/
.btn-confirm-yellow {
  display: flex; align-items: center; justify-content: center;
  height: 90rpx; padding: 0 40rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-focus-yellow);
  color: #725d42;
  border: 2px solid var(--color-focus-yellow);
  box-shadow: 0 10rpx 0 0 var(--color-focus-yellow-d);
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-confirm-yellow:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 0 0 var(--color-focus-yellow-d);
}
.btn-confirm-yellow:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 var(--color-focus-yellow-d);
}

/* ============================================
 * 3D Pill 输入框
 * ============================================ */
.input {
  height: 80rpx;
  padding: 0 36rpx;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 0.01em;
  color: #725d42;
  background: rgb(247, 243, 223);
  border: 5rpx solid var(--color-border-light);
  border-radius: 100rpx;
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  box-sizing: border-box;
  width: 100%;
  transition: all var(--motion-base) var(--motion-ease);
}
.input::placeholder {
  color: var(--color-text-disabled);
  font-weight: 400;
}
.input:focus {
  border-color: var(--color-focus-yellow) !important;
  box-shadow: 0 6rpx 0 0 var(--color-focus-yellow-d),
              0 0 0 6rpx rgba(255, 204, 0, 0.15);
}
.input[disabled] {
  background: var(--color-bg-input-dis);
  border-color: var(--color-shadow-input);
  box-shadow: none;
  opacity: 0.6;
}

.textarea {
  width: 100%; min-height: 160rpx;
  padding: 24rpx 36rpx;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 0.01em;
  color: #725d42;
  background: rgb(247, 243, 223);
  border: 5rpx solid var(--color-border-light);
  border-radius: 40rpx;
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  box-sizing: border-box;
  transition: all var(--motion-base) var(--motion-ease);
}
.textarea:focus {
  border-color: var(--color-focus-yellow) !important;
  box-shadow: 0 6rpx 0 0 var(--color-focus-yellow-d),
              0 0 0 6rpx rgba(255, 204, 0, 0.15);
}

/* ============================================
 * 标签（pill 圆角）
 * ============================================ */
.tag {
  display: inline-flex; align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;                    /* pill */
  font-size: var(--font-size-xs);
  font-weight: 500;
  border: 3rpx solid transparent;
  letter-spacing: 0.01em;
}
.tag-blue   { background: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary); }
.tag-green  { background: #e8f5e0; color: var(--color-success); border-color: var(--color-success); }
.tag-red    { background: #fde8e8; color: var(--color-error); border-color: var(--color-error); }
.tag-orange { background: #fef4e6; color: #d4730b; border-color: var(--color-warning); }
.tag-gold   { background: #fef7e0; color: #b8860b; border-color: var(--color-warning); }
.tag-gray   { background: var(--color-bg-disabled); color: var(--color-text-disabled); border-color: var(--color-border-light); }

/* ============================================
 * 分隔装饰（Divider）
 * ============================================ */
.divider-line {
  width: 100%; height: 24rpx;              /* 12px */
  background: var(--color-text-disabled);
  opacity: 0.5;
  border-radius: 4rpx;
  margin: var(--spacing-md) 0;
}

/* 波浪底部分隔 */
.footer-wave {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(25, 200, 185, 0.1) 50%,
    rgba(25, 200, 185, 0.2) 100%
  );
  border-radius: 50% 50% 0 0 / 20rpx 20rpx 0 0;
  margin-top: 48rpx;
  position: relative;
}
.footer-wave::before {
  content: '〰';
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 60rpx;
  color: var(--color-primary);
  opacity: 0.6;
  letter-spacing: 20rpx;
}

/* ============================================
 * 装饰元素
 * ============================================ */
.leaf-decor {
  display: inline-block;
  font-size: 32rpx;
  opacity: 0.7;
  animation: leaf-wiggle 3s ease-in-out infinite;
}
@keyframes leaf-wiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-8deg) scale(1.05); }
  75% { transform: rotate(8deg) scale(1.05); }
}

.animal-decor {
  font-size: 40rpx;
  filter: drop-shadow(0 4rpx 4rpx rgba(61, 52, 40, 0.15));
}

/* 叶子背景装饰 */
.leaf-bg {
  position: fixed;
  font-size: 120rpx;
  opacity: 0.08;
  pointer-events: none;
  z-index: 0;
}
.leaf-bg-1 { top: 100rpx; right: -20rpx; transform: rotate(45deg); }
.leaf-bg-2 { bottom: 200rpx; left: -30rpx; transform: rotate(-30deg); }

/* ============================================
 * 卡片标题
 * ============================================ */
.card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
  letter-spacing: 0.02em;
}

/* ============================================
 * 工具类
 * ============================================ */
.hint { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.primary { color: var(--color-primary); }
.error { color: var(--color-error); }

.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 16rpx; }
.gap-16 { gap: 24rpx; }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 16rpx; }
.mt-16 { margin-top: 24rpx; }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 24rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

/* 空状态 */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 96rpx 32rpx; color: var(--color-text-muted); font-size: var(--font-size-base);
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }

.load-more { text-align: center; padding: 32rpx; font-size: var(--font-size-sm); color: var(--color-text-secondary); }

/* 头像 */
.avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  border: 5rpx solid var(--color-primary);
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary);
  font-weight: 700; font-size: var(--font-size-base);
  overflow: hidden;
}

/* ============================================
 * NookPhone 色板卡片（可选）
 * ============================================ */
.card-app-pink       { background: #f8a6b2 !important; color: #fff !important; }
.card-purple         { background: #b77dee !important; color: #fff !important; }
.card-app-blue       { background: #889df0 !important; color: #fff !important; }
.card-app-yellow     { background: #f7cd67 !important; color: #725d42 !important; }
.card-app-orange     { background: #e59266 !important; color: #fff !important; }
.card-app-teal       { background: #82d5bb !important; color: #fff !important; }
.card-app-green      { background: #8ac68a !important; color: #fff !important; }
.card-app-red        { background: #fc736d !important; color: #fff !important; }
.card-lime-green     { background: #d1da49 !important; color: #3d5a1a !important; }
.card-yellow-green   { background: #ecdf52 !important; color: #725d42 !important; }
.card-brown          { background: #9a835a !important; color: #fff !important; }
.card-warm-peach-pink{ background: #e18c6f !important; color: #fff !important; }

/* ===========================================
 * 空状态 & 加载动画（全局）
 * =========================================== */
.empty {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 80rpx 40rpx;
}
.empty-img {
  width: 400rpx; height: 400rpx; margin-bottom: 32rpx;
}
.empty-text {
  font-size: var(--font-size-base); color: var(--color-text-secondary);
  letter-spacing: 0.05em;
}

/* 加载中 — 叶片旋转动画（NookPhone 风格）*/
.leaf-spin {
  font-size: 64rpx;
  animation: leafSpin 1.2s ease-in-out infinite;
  transform-origin: center center;
}
@keyframes leafSpin {
  0%   { transform: rotate(0deg) scale(1); }
  25%  { transform: rotate(8deg) scale(1.05); }
  50%  { transform: rotate(0deg) scale(1); }
  75%  { transform: rotate(-8deg) scale(1.05); }
  100% { transform: rotate(0deg) scale(1); }
}

/* ===========================================
 * 全局换页过渡动画（TabBar 页面切换）
 * =========================================== */
@keyframes anisland-fadein {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes anisland-zoomin {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes anisland-fadeup {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes anisland-slideup {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
/* 给所有 TabBar 页面内容入口加淡入动画 */
.tab-content,
.task-list,
.msg-item:first-child,
.form-page,
.profile > view,
.duty-table { animation: anisland-fadeup 0.25s ease; }
