/* ============================================
 * Animal Island Theme — 辅助组件样式
 * 主样式已移至 app.wxss
 * ============================================ */

/* ===== 有机形状标题卡片 ===== */
.anisland-card-title {
  background: #fdfdf5;
  border-radius: 80rpx 70rpx 90rpx 76rpx / 76rpx 90rpx 70rpx 80rpx;
  padding: 24rpx 64rpx;
  font-weight: 600;
}

/* ===== 弹窗(Sheet) ===== */
.anisland-sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 1000;
  display: flex; align-items: flex-end;
  animation: anisland-fadein var(--motion-base) ease;
}
.anisland-sheet {
  width: 100%;
  background: var(--color-bg-content);
  border-radius: 64rpx 64rpx 0 0;
  padding: 48rpx 48rpx 32rpx 48rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -16rpx 48rpx rgba(61, 52, 40, 0.14);
  animation: anisland-zoomin 0.3s ease;
}
.anisland-sheet-title {
  font-size: 56rpx;
  font-weight: 700;
  color: rgba(114, 93, 66, 1);
  text-align: center;
  margin-bottom: 30rpx;
}

/* ===== TabBar 底部导航 ===== */
.anisland-tabbar {
  display: flex;
  background: var(--color-bg);
  border-top: 4rpx solid var(--color-border-light);
  padding-bottom: env(safe-area-inset-bottom);
}
.anisland-tabbar-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 8rpx 0;
  font-size: 20rpx; font-weight: 500;
  color: var(--color-text-muted);
  transition: color var(--motion-fast);
}
.anisland-tabbar-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ===== 动画 ===== */
@keyframes anisland-fadein {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes anisland-zoomin {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes anisland-fadeup {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes anisland-slideup {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
