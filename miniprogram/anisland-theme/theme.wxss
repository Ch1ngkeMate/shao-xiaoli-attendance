/* ============================================
 * Animal Island Theme — Design Tokens
 * Inspired by Animal Crossing: New Horizons
 * ============================================ */

page {
  /* ---------- 主色调 ---------- */
  --color-primary: #19c8b9;
  --color-primary-hover: #3dd4c6;
  --color-primary-active: #50B9AB;
  --color-primary-bg: #e6f9f6;

  /* ---------- 功能色 ---------- */
  --color-success: #6fba2c;
  --color-success-hover: #85cc45;
  --color-success-active: #5a9e1e;

  --color-warning: #f5c31c;
  --color-warning-hover: #f7d04a;
  --color-warning-active: #dba90e;

  --color-error: #e05a5a;
  --color-error-hover: #e87878;
  --color-error-active: #c94444;

  /* ---------- 中性色 / 文字 ---------- */
  --color-text: #794f27;
  --color-text-secondary: #9f927d;
  --color-text-disabled: #c4b89e;

  --color-border: #aaa69d;
  --color-border-hover: #827157;
  --color-border-light: #e8e2d6;

  /* ---------- 背景 ---------- */
  --color-bg: #f8f8f0;
  --color-bg-container: #fffef5;
  --color-bg-secondary: #f0e8d8;
  --color-bg-disabled: #f0ece2;
  --color-bg-mask: rgba(61, 52, 40, 0.45);

  /* ---------- 间距 ---------- */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* ---------- 圆角 ---------- */
  --border-radius-sm: 16rpx;
  --border-radius-base: 24rpx;
  --border-radius-lg: 32rpx;
  --border-radius-round: 999rpx;

  /* ---------- 阴影 ---------- */
  --shadow-sm: 0 4rpx 8rpx 0 rgba(61, 52, 40, 0.06);
  --shadow-base: 0 6rpx 20rpx 0 rgba(61, 52, 40, 0.10);
  --shadow-lg: 0 16rpx 48rpx 0 rgba(61, 52, 40, 0.14);

  /* ---------- 字体 ---------- */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-title: 36rpx;

  /* ---------- 尺寸 ---------- */
  --height-sm: 60rpx;
  --height-base: 80rpx;
  --height-lg: 96rpx;

  /* ---------- 动画 ---------- */
  --motion-fast: 0.15s;
  --motion-base: 0.25s;
  --motion-slow: 0.35s;
  --motion-ease: cubic-bezier(0.4, 0, 0.2, 1);
}
