/* ============================================
 * Animal Island Theme — Pixel-perfect Design Tokens
 * Source: SKILL.md / variables.less
 * ============================================ */

page {
  /* ===== 字体 ===== */
  --animal-font: Nunito, 'Noto Sans SC', 'Zen Maru Gothic',
    -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

  /* ===== 主色（薄荷青绿）===== */
  --color-primary: #19c8b9;
  --color-primary-hover: #3dd4c6;
  --color-primary-active: #11a89b;
  --color-primary-bg: #e6f9f6;

  /* ===== 文字（温暖棕色系）===== */
  --color-text: #794f27;           /* header / sidebar */
  --color-text-body: #725d42;      /* 正文 */
  --color-text-secondary: #9f927d;
  --color-text-muted: #8a7b66;
  --color-text-disabled: #c4b89e;

  /* ===== 边框 ===== */
  --color-border: #9f927d;
  --color-border-light: #c4b89e;   /* 输入框边框 */
  --color-border-hover: #a89878;

  /* ===== 背景（奶油米白）===== */
  --color-bg: #f8f8f0;             /* 主背景 */
  --color-bg-content: rgb(247, 243, 223);  /* 内容区（卡片/弹窗）*/
  --color-bg-container: rgb(247, 243, 223);
  --color-bg-secondary: #f0e8d8;
  --color-bg-disabled: #f0ece2;
  --color-bg-input: rgb(247, 243, 223);
  --color-bg-input-dis: #ece8dc;

  /* ===== 状态色 ===== */
  --color-success: #6fba2c;
  --color-success-active: #5a9e1e;
  --color-warning: #f5c31c;
  --color-warning-active: #dba90e;
  --color-error: #e05a5a;
  --color-error-active: #c94444;

  /* ===== 游戏特殊色 ===== */
  --color-focus-yellow: #ffcc00;
  --color-focus-yellow-d: #e0b800;
  --color-sidebar-active: #B7C6E5;
  --color-sidebar-hover: #d6dff0;

  /* ===== 3D 阴影色（核心特征）===== */
  --color-shadow-btn: #bdaea0;
  --color-shadow-input: #d4c9b4;
  --color-shadow-switch: #5a9e1e;

  /* ===== 圆角 ===== */
  --border-radius-sm: 12px;
  --border-radius-base: 18px;
  --border-radius-lg: 20px;
  --border-radius-pill: 50px;
  --border-radius-organic: 40px 35px 45px 38px / 38px 45px 35px 40px;

  /* ===== 字体大小 ===== */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-title: 40rpx;

  /* ===== 间距（1px≈2rpx）===== */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* ===== 动效 ===== */
  --motion-fast: 0.15s;
  --motion-base: 0.25s;
  --motion-slow: 0.35s;
  --motion-ease: cubic-bezier(0.4, 0, 0.2, 1);
}

/* ===== NookPhone 调色板（13色）===== */
