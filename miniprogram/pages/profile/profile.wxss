/* 个人主页 */

.profile-card {
  position: relative;
  overflow: hidden;
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 24rpx;
}

.profile-bg {
  width: 100%;
  height: 280rpx;
  background-size: cover;
  background-position: center;
}

.profile-bg-default {
  background: linear-gradient(135deg, #1677ff, #69b1ff);
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -60rpx;
  padding: 0 32rpx 40rpx;
  position: relative;
  z-index: 1;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background: #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
}

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e6f4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 4rpx solid #fff;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 白色卡片区域 */
.stat-row {
  display: flex;
  justify-content: space-around;
  margin: 16rpx 0;
}

.stat-cell {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1677ff;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
