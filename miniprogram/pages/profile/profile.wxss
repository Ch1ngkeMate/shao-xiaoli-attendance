/* 复刻 Web 端个人主页 */

/* ===== 封面卡片 ===== */
.cover-card {
  position: relative; height: 440rpx;
  margin: 0 0 24rpx;
  border-radius: 0 0 28rpx 28rpx;
  overflow: hidden;
}

.cover-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}

.cover-bg-empty {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 40%, var(--color-primary) 100%);
}

/* 渐变遮罩 — 有背景图时 */
.cover-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom,
    rgba(0,0,0,0.05) 0%,
    rgba(0,0,0,0.35) 55%,
    rgba(0,0,0,0.60) 100%);
}

/* 底部内容区 */
.cover-content {
  position: absolute; left: 28rpx; right: 28rpx; bottom: 28rpx;
  display: flex; align-items: center; gap: 24rpx;
}

/* 头像 */
.cover-avatar {
  width: 144rpx; height: 144rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.85);
  flex-shrink: 0;
  background: rgba(255,255,255,0.15);
}

.cover-avatar-placeholder {
  display: flex; align-items: center; justify-content: center;
  font-size: 72rpx;
  background: rgba(255,255,255,0.2);
}

/* 文字区 */
.cover-text { flex: 1; min-width: 0; }

.cover-name {
  font-size: 36rpx; font-weight: 700; line-height: 1.2;
  color: rgba(255,255,255,0.96);
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.cover-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.25);
}

/* ===== 考勤摘要卡片 ===== */
.card-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.stat-row {
  display: flex; justify-content: space-around;
}

.stat-cell { text-align: center; }

.stat-num {
  font-size: 48rpx; font-weight: 700;
  color: var(--color-text); line-height: 1.2;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* ===== 菜单 ===== */
.menu-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--spacing-sm) 0;
  font-size: var(--font-size-base);
}
.menu-row + .menu-row { border-top: 1rpx solid var(--color-split); }

.menu-logout { color: var(--color-error); }
