<view wx:if="{{user}}">
  <!-- 封面卡片 — 复刻 Web 端 -->
  <view class="cover-card">
    <image wx:if="{{user.profileBgUrl}}" src="{{user.profileBgUrl}}" class="cover-bg" mode="aspectFill" />
    <view wx:else class="cover-bg cover-bg-empty"></view>
    <view wx:if="{{user.profileBgUrl}}" class="cover-overlay"></view>
    <view class="cover-content">
      <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="cover-avatar" mode="aspectFill" />
      <view wx:else class="cover-avatar cover-avatar-placeholder">👤</view>
      <view class="cover-text">
        <view class="cover-name">{{user.displayName}}</view>
        <view class="cover-meta">{{user.username}} · {{roleText}}</view>
      </view>
    </view>
  </view>

  <!-- 考勤摘要 -->
  <view wx:if="{{attendanceSummary}}" class="card">
    <view class="card-title">我的考勤</view>
    <view class="stat-row">
      <view class="stat-cell">
        <view class="stat-num">{{attendanceSummary.claimCount || 0}}</view>
        <view class="stat-label">参与任务</view>
      </view>
      <view class="stat-cell">
        <view class="stat-num">{{attendanceSummary.submitCount || 0}}</view>
        <view class="stat-label">已提交</view>
      </view>
      <view class="stat-cell">
        <view class="stat-num">{{attendanceSummary.approvedCount || 0}}</view>
        <view class="stat-label">已完成</view>
      </view>
      <view class="stat-cell">
        <view class="stat-num primary">+{{attendanceSummary.approvedPoints || 0}}</view>
        <view class="stat-label">积分</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="menu-row" bindtap="onSettings">
      <text>⚙️ 设置</text>
      <text class="hint">›</text>
    </view>
    <view wx:if="{{isAdminOrMinister}}" class="menu-row" bindtap="onReports">
      <text>📊 月报</text>
      <text class="hint">›</text>
    </view>
    <view class="menu-row menu-logout" bindtap="onLogout">
      <text>🚪 退出登录</text>
      <text class="hint">›</text>
    </view>
  </view>
</view>

<!-- 空状态 & 加载中 -->
<view wx:else class="empty">
  <image wx:if="{{!loading}}" class="empty-img" src="/assets/empty-profile.webp" mode="aspectFit" />
  <view wx:if="{{!loading}}" class="empty-text">请先登录</view>
  <view wx:if="{{loading}}" class="leaf-spin">🍃</view>
  <view wx:if="{{loading}}" class="empty-text">加载中...</view>
</view>
