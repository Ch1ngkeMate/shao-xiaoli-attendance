/* 发布任务 */

.form-page {
  padding: 20rpx 0 120rpx;
}

.form-group {
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-input-sm {
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  width: 120rpx;
  text-align: center;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 时间段 */
.slot-tag {
  background: #e6f4ff;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}
.slot-remove {
  color: #ff4d4f;
  font-size: 32rpx;
  padding: 0 8rpx;
}

.slot-add {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}
.slot-pickers {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.slot-picker-item {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
.btn-sm-inline {
  margin-top: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

/* 图片 */
.evidence-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.evidence-img-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.evidence-img {
  width: 100%;
  height: 100%;
}
.evidence-remove {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.evidence-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.evidence-add-icon {
  font-size: 48rpx;
  color: #1677ff;
}

.submit-area {
  padding: 32rpx 20rpx;
}

.btn-full {
  width: 100%;
}
