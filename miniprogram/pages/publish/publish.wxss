/* 发布任务 */

.form-page {
  padding: 20rpx 0 120rpx;
}

.form-group {
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  height: 80rpx;
  background: var(--color-bg-secondary);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-input-sm {
  height: 60rpx;
  background: var(--color-bg-secondary);
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  width: 120rpx;
  text-align: center;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--color-bg-secondary);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 积分选择器 */
.point-active {
  background: var(--color-primary-bg) !important;
  border-color: var(--color-primary) !important;
  color: var(--color-primary) !important;
}

/* 时间段 */
.slot-tag {
  background: var(--color-primary-bg);
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}
.slot-remove {
  color: var(--color-error);
  font-size: 32rpx;
  padding: 0 8rpx;
}

.slot-add {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}
.slot-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.slot-label {
  width: 72rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
}
.slot-picker-item {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
}
.slot-picker-placeholder {
  color: #999;
}
.btn-sm-inline {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  margin-left: auto;
}

/* 图片 */
.evidence-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.evidence-img-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.evidence-img {
  width: 100%;
  height: 100%;
}
.evidence-remove {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.evidence-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.evidence-add-icon {
  font-size: 48rpx;
  color: var(--color-primary);
}

.submit-area {
  padding: 32rpx 20rpx;
}

.btn-full {
  width: 100%;
}

/* 转发引导弹窗 */
.share-tip-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-tip-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.share-tip-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.share-tip-title {
  font-size: 36rpx; font-weight: 700;
  margin-bottom: 8rpx;
}
.share-tip-body {
  font-size: 26rpx; color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}
.share-tip-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}
.btn-share {
  width: 100%; height: 80rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 12rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  line-height: 80rpx;
}
.btn-close-share {
  width: 100%; height: 72rpx;
  background: var(--color-bg-secondary); color: #999;
  font-size: 26rpx;
  border-radius: 12rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  line-height: 72rpx;
}
