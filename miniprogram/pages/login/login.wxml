<!-- 品牌区 — 对齐 Web 端 DeptLogo -->
<view class="brand-area">
  <image wx:if="{{!logoFailed}}" class="brand-logo" src="{{logoUrl}}" mode="aspectFit" binderror="onLogoError" />
  <view wx:else class="brand-logo">
    <text class="brand-logo-heart">♥</text>
  </view>
  <view class="brand-title">干事考勤系统</view>
  <view class="brand-subtitle">宣传部</view>
</view>

<view class="card">
  <view class="title">首次使用请绑定</view>
  <view class="hint">请输入与系统一致的「显示姓名」，绑定后可微信一键登录。</view>
  <input
    class="input"
    placeholder="真实姓名（与系统 displayName 一致）"
    value="{{realName}}"
    bindinput="onNameInput"
  />
  <button class="btn-primary" type="primary" loading="{{loading}}" bindtap="onBind">
    微信授权并绑定
  </button>
  <button class="btn-ghost" loading="{{loading}}" bindtap="onWxLogin">
    已绑定，直接登录
  </button>
</view>
