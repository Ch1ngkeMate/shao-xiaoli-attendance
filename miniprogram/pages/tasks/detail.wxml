<wxs module="utils">
  var pad2 = function(n) { return n < 10 ? '0'+n : ''+n; };
  var formatTime = function(s) {
    if (!s) return '';
    var d = getDate(s);
    return pad2(d.getMonth()+1)+'-'+pad2(d.getDate())+' '+pad2(d.getHours())+':'+pad2(d.getMinutes());
  };
  var inArray = function(arr, val) {
    if (!arr) return false;
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === val) return true;
    }
    return false;
  };
  module.exports = { formatTime:formatTime, inArray:inArray };
</wxs>

<view wx:if="{{loading}}" class="load-more">加载中...</view>
<view wx:if="{{!loading && !task}}" class="load-more">任务不存在</view>

<view wx:if="{{task}}">
  <swiper wx:if="{{task.images && task.images.length > 0}}" class="image-swiper" indicator-dots circular>
    <swiper-item wx:for="{{task.images}}" wx:key="id">
      <image src="{{item.url}}" mode="aspectFill" class="swiper-image" data-urls="{{task.imageUrls}}" data-current="{{item.url}}" bindtap="onPreviewImage" />
    </swiper-item>
  </swiper>

  <!-- 标题区 -->
  <view class="card">
    <view class="flex-row gap-12">
      <view class="detail-title ellipsis">{{task.title}}</view>
    </view>
    <view class="flex-row gap-12 mt-12">
      <view wx:if="{{task.status === 'CLOSED' || allClaimantsApproved}}" class="tag tag-gray">已结束</view>
      <view wx:elif="{{isTimeEnded && task.claimedCount > 0 && !allClaimantsApproved}}" class="tag tag-orange">待处理</view>
      <view wx:elif="{{slotsOrTaskFull}}" class="tag tag-orange">名额已满</view>
      <view wx:else class="tag tag-green">可接取</view>
      <view class="tag tag-blue">+{{task.points}} 分</view>
    </view>
    <view wx:if="{{task.publisher}}" class="hint mt-12">发布人: {{task.publisher.displayName}}</view>
  </view>

  <!-- 信息区 -->
  <view class="card">
    <view class="info-row">
      <view class="info-label">进行时间</view>
      <view class="info-value">
        <view wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
          <view wx:for="{{task.timeSlots}}" wx:key="id" class="slot-line">
            {{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}
            <text wx:if="{{item.limit}}" class="hint">（限{{item.limit}}人）</text>
          </view>
        </view>
        <view wx:else>
          {{utils.formatTime(task.startTime)}} — {{utils.formatTime(task.endTime)}}
        </view>
      </view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">积分</view>
      <view class="info-value">{{task.points}}</view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">人数</view>
      <view class="info-value">{{task.headcountHint || '不限制'}}</view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">描述</view>
      <view class="info-value">{{task.description || '无'}}</view>
    </view>
  </view>

  <!-- 已接取人员 — task.claims -->
  <view class="card">
    <view class="card-title">已接取人员</view>
    <view wx:if="{{task.claims && task.claims.length > 0}}">
      <view wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
        <view wx:for="{{task.timeSlots}}" wx:key="id" class="slot-claim-group">
          <view class="slot-label">{{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}</view>
          <view class="claimant-tags">
            <view wx:for="{{task.claims}}" wx:for-item="c" wx:key="id">
              <view wx:if="{{c.timeSlotId === item.id}}" class="claimant-tag">
                <image wx:if="{{c.user.avatarUrl}}" src="{{c.user.avatarUrl}}" class="avatar-xs" mode="aspectFill" />
                <view wx:else class="avatar-xs avatar-placeholder-xs">👤</view>
                <text class="claimant-tag-name">{{c.user.displayName}}</text>
                <text wx:if="{{isAdminOrMinister && task.status === 'OPEN'}}" class="remove-claimant" data-claim-id="{{c.id}}" bindtap="onRemoveTap">✕</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="claimant-tags">
        <view wx:for="{{task.claims}}" wx:key="id" class="claimant-tag">
          <image wx:if="{{item.user.avatarUrl}}" src="{{item.user.avatarUrl}}" class="avatar-xs" mode="aspectFill" />
          <view wx:else class="avatar-xs avatar-placeholder-xs">👤</view>
          <text class="claimant-tag-name">{{item.user.displayName}}</text>
          <text wx:if="{{isAdminOrMinister && task.status === 'OPEN'}}" class="remove-claimant" data-claim-id="{{item.id}}" bindtap="onRemoveTap">✕</text>
        </view>
      </view>
    </view>
    <view wx:else class="hint" style="padding:20rpx 0;">暂无人接取</view>
  </view>

  <!-- 我的操作 -->
  <view wx:if="{{task.status === 'OPEN'}}" class="card">
    <view class="card-title">我的操作</view>
    <view wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
      <view wx:for="{{task.timeSlots}}" wx:key="id" class="flex-between claim-slot-row">
        <view class="flex-row gap-8">
          <text class="hint">{{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}</text>
          <!-- 我已接取该时段 -->
          <text wx:if="{{utils.inArray(myClaimedSlotIds, item.id)}}" class="tag tag-green">已接</text>
          <!-- 满了 -->
          <text wx:elif="{{item.limit && item.claimedCount >= item.limit}}" class="tag tag-red">已满</text>
          <!-- 可接 -->
          <text wx:else class="tag tag-blue">可接</text>
        </view>
        <button wx:if="{{!utils.inArray(myClaimedSlotIds, item.id) && (!item.limit || item.claimedCount < item.limit)}}"
          class="btn-primary btn-sm-inline" style="padding:0 16rpx;min-width:80rpx;" data-slot-id="{{item.id}}" bindtap="onClaim">接取</button>
        <text wx:else class="hint">—</text>
      </view>
      <view wx:if="{{hasClaimed}}" style="margin-top:16rpx;">
        <button class="btn-primary" bindtap="onOpenSubmit" style="width:100%">提交完成凭证</button>
      </view>
    </view>
    <view wx:else>
      <view wx:if="{{hasClaimed}}">
        <button class="btn-primary" bindtap="onOpenSubmit" style="width:100%">提交完成凭证</button>
      </view>
      <view wx:else>
        <button class="btn-primary" bindtap="onClaim">接取任务</button>
      </view>
    </view>
  </view>

  <!-- 审核列表 -->
  <view wx:if="{{isAdminOrMinister && submissionsForReview && submissionsForReview.length > 0}}" class="card">
    <view class="card-title">待审核/已审核列表</view>
    <view wx:for="{{submissionsForReview}}" wx:key="id" class="review-item">
      <view class="flex-between">
        <view class="flex-row gap-8">
          <text class="review-user">{{item.user.displayName}}</text>
          <view wx:if="{{!item.review}}" class="tag tag-gold">待审核</view>
          <view wx:elif="{{item.review.result === 'APPROVED'}}" class="tag tag-green">已通过</view>
          <view wx:else class="tag tag-red">已驳回</view>
        </view>
        <view wx:if="{{!item.review}}" class="flex-row gap-8">
          <button class="btn-primary btn-sm-inline" data-submission-id="{{item.id}}" data-result="APPROVED" bindtap="onReview">通过</button>
          <button class="btn-sm-inline btn-danger-inline" data-submission-id="{{item.id}}" data-result="REJECTED" bindtap="onReview">驳回</button>
        </view>
      </view>
      <view wx:if="{{item.note}}" class="hint mt-8">{{item.note}}</view>
      <view wx:if="{{item.review && item.review.reason}}" class="hint mt-8 error">驳回原因：{{item.review.reason}}</view>
    </view>
  </view>

  <!-- 管理操作 -->
  <view wx:if="{{task.status === 'OPEN' && isAdminOrMinister}}" class="card">
    <view class="card-title">管理操作</view>
    <view class="hint" style="margin-bottom:16rpx;">收工：任务正常结束<br/>提前结束：整单不计考勤</view>
    <view class="flex-row gap-12">
      <button class="btn-primary" bindtap="onCloseTask" data-exclude="false" style="flex:1">收工</button>
      <button class="btn-danger" bindtap="onConfirmCloseSkip" style="flex:1">提前结束</button>
    </view>
  </view>
</view>

<!-- ===== 弹窗 ===== -->
<view wx:if="{{showSubmitSheet}}" class="sheet-overlay" bindtap="onCloseSubmitSheet">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">提交完成凭证</view>
    <textarea class="textarea" placeholder="备注说明（选填）" value="{{submitNote}}" bindinput="onNoteInput" maxlength="500" />
    <view class="evidence-images mt-16">
      <view wx:for="{{evidenceUrls}}" wx:key="*this" class="evidence-img-wrap">
        <image src="{{item}}" mode="aspectFill" class="evidence-img" />
        <view class="evidence-remove" data-index="{{index}}" bindtap="removeImage">×</view>
      </view>
      <view wx:if="{{evidenceUrls.length < 9}}" class="evidence-add" bindtap="onChooseImage">
        <view class="evidence-add-icon">+</view>
        <view class="hint">{{uploading ? '上传中' : '添加图片'}}</view>
      </view>
    </view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseSubmitSheet" style="flex:1">取消</button>
      <button class="btn-primary" bindtap="onSubmit" style="flex:2">确认提交</button>
    </view>
  </view>
</view>

<view wx:if="{{showCloseConfirm}}" class="sheet-overlay" bindtap="onCloseCloseConfirm">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">确认{{excludeAttendance ? '提前结束' : '收工'}}</view>
    <view class="mt-16">{{excludeAttendance ? '整单不计考勤，确定吗？' : '确定收工吗？已通过人员会计考勤。'}}</view>
    <view class="flex-row mt-16 gap-12" bindtap="onExcludeChange">
      <text>{{excludeAttendance ? '☑' : '☐'}}</text>
      <text>不计入考勤</text>
    </view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseCloseConfirm" style="flex:1">取消</button>
      <button class="btn-danger" bindtap="onConfirmClose" style="flex:2">确认</button>
    </view>
  </view>
</view>
