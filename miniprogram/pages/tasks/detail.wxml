<wxs module="utils">
  var pad2 = function(n) { return n < 10 ? '0'+n : ''+n; };
  var formatTime = function(s) {
    if (!s) return '';
    var d = getDate(s);
    return pad2(d.getMonth()+1)+'-'+pad2(d.getDate())+' '+pad2(d.getHours())+':'+pad2(d.getMinutes());
  };
  module.exports = { formatTime:formatTime };
</wxs>

<view wx:if="{{loading}}" class="load-more">加载中...</view>

<view wx:if="{{!loading && !task}}" class="load-more">任务不存在</view>

<view wx:if="{{task}}">
  <!-- 图片轮播 -->
  <swiper wx:if="{{task.images && task.images.length > 0}}" class="image-swiper" indicator-dots circular>
    <swiper-item wx:for="{{task.images}}" wx:key="id">
      <image src="{{item.url}}" mode="aspectFill" class="swiper-image" />
    </swiper-item>
  </swiper>

  <!-- 标题区 -->
  <view class="card">
    <view class="flex-row gap-12">
      <view class="detail-title ellipsis">{{task.title}}</view>
    </view>
    <view class="flex-row gap-12 mt-12">
      <view wx:if="{{task.status === 'OPEN'}}" class="tag tag-gold">待处理</view>
      <view wx:else class="tag tag-gray">已结束</view>
      <view class="tag tag-blue">+{{task.points}} 分</view>
    </view>
    <view wx:if="{{task.publisher}}" class="hint mt-12">发布人: {{task.publisher.displayName}}</view>
  </view>

  <!-- 信息区 -->
  <view class="card">
    <view class="info-row">
      <view class="info-label">进行时间</view>
      <view class="info-value">
        <block wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
          <view wx:for="{{task.timeSlots}}" wx:key="id" class="slot-line">
            {{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}
            <text wx:if="{{item.headcountHint}}" class="hint">（限{{item.headcountHint}}人）</text>
          </view>
        </block>
        <block wx:else>
          {{utils.formatTime(task.startTime)}} — {{utils.formatTime(task.endTime)}}
        </block>
      </view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">积分</view>
      <view class="info-value">{{task.points}}</view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">人数</view>
      <view class="info-value">{{task.headcountHint || '不限制'}}</view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <view class="info-label">描述</view>
      <view class="info-value">{{task.description || '无'}}</view>
    </view>
  </view>

  <!-- 已接取人员 -->
  <view class="card">
    <view class="card-title">已接取人员</view>
    <block wx:if="{{task.claims && task.claims.length > 0}}">
      <!-- 按时段分组 -->
      <block wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
        <view wx:for="{{task.timeSlots}}" wx:key="id" class="slot-claim-group">
          <view class="slot-label">{{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}</view>
          <view class="claimant-tags">
            <block wx:for="{{task.claims}}" wx:for-item="claim" wx:key="id">
              <view wx:if="{{claim.timeSlotId === item.id}}" class="claimant-tag">
                <image wx:if="{{claim.user.avatarUrl}}" src="{{claim.user.avatarUrl}}" class="avatar-xs" mode="aspectFill" />
                <view wx:else class="avatar-xs avatar-placeholder-xs">👤</view>
                <text class="claimant-tag-name">{{claim.user.displayName}}</text>
              </view>
            </block>
            <view wx:if="{{item.claimedCount === 0}}" class="hint">暂无</view>
          </view>
        </view>
      </block>
      <!-- 无时段 -->
      <view wx:else class="claimant-tags">
        <view wx:for="{{task.claims}}" wx:key="id" class="claimant-tag">
          <image wx:if="{{item.user.avatarUrl}}" src="{{item.user.avatarUrl}}" class="avatar-xs" mode="aspectFill" />
          <view wx:else class="avatar-xs avatar-placeholder-xs">👤</view>
          <text class="claimant-tag-name">{{item.user.displayName}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="hint" style="padding:20rpx 0;">暂无人接取</view>
  </view>

  <!-- 我的操作 -->
  <view wx:if="{{task.status === 'OPEN'}}" class="card">
    <view class="card-title">我的操作</view>
    <!-- 已接 -->
    <block wx:if="{{hasClaimed}}">
      <view wx:for="{{task.claims}}" wx:for-item="claim" wx:key="id">
        <block wx:if="{{claim.user && claim.user.id === me.id && claim.status === 'CLAIMED'}}">
          <view class="flex-between">
            <view>
              <view wx:if="{{claim.timeSlot}}" class="hint">已接时段: {{utils.formatTime(claim.timeSlot.startTime)}} — {{utils.formatTime(claim.timeSlot.endTime)}}</view>
              <view wx:else class="hint">已接取任务</view>
            </view>
            <button class="btn-link" bindtap="onCancelClaimTap">取消接取</button>
          </view>
          <!-- 提交按钮 -->
          <button wx:if="{{!claim.submitted}}" class="btn-primary mt-12" bindtap="onOpenSubmit" style="width:100%">提交完成凭证</button>
        </block>
      </block>
    </block>
    <!-- 未接 -->
    <view wx:else>
      <block wx:if="{{task.timeSlots && task.timeSlots.length > 0}}">
        <view wx:for="{{task.timeSlots}}" wx:key="id" class="flex-between claim-slot-row">
          <view class="flex-row gap-8">
            <text class="hint">{{utils.formatTime(item.startTime)}} — {{utils.formatTime(item.endTime)}}</text>
            <text wx:if="{{item.claimedCount >= item.headcountHint}}" class="tag tag-red">已满</text>
            <text wx:else class="tag tag-blue">可接</text>
          </view>
          <button wx:if="{{item.claimedCount < item.headcountHint}}" class="btn-primary btn-sm-inline" data-slot-id="{{item.id}}" bindtap="onClaim">接取</button>
        </view>
      </block>
      <button wx:else class="btn-primary" bindtap="onClaim">接取任务</button>
    </view>
  </view>

  <!-- 关单（管理员/部长） -->
  <view wx:if="{{task.status === 'OPEN' && isAdminOrMinister}}" class="card">
    <button class="btn-danger" bindtap="onCloseTask" style="width:100%">关单 / 提前结束</button>
  </view>
</view>

<!-- ===== 弹窗 ===== -->
<view wx:if="{{showSubmitSheet}}" class="sheet-overlay" bindtap="onCloseSubmitSheet">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">提交完成凭证</view>
    <textarea class="textarea" placeholder="备注说明（选填）" value="{{submitNote}}" bindinput="onNoteInput" maxlength="500" />
    <view class="evidence-images mt-16">
      <block wx:for="{{evidenceUrls}}" wx:key="*this">
        <view class="evidence-img-wrap">
          <image src="{{item}}" mode="aspectFill" class="evidence-img" />
          <view class="evidence-remove" data-index="{{index}}" bindtap="removeImage">×</view>
        </view>
      </block>
      <view wx:if="{{evidenceUrls.length < 9}}" class="evidence-add" bindtap="onChooseImage">
        <view class="evidence-add-icon">+</view>
        <view class="hint">{{uploading ? '上传中' : '添加图片'}}</view>
      </view>
    </view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseSubmitSheet" style="flex:1">取消</button>
      <button class="btn-primary" bindtap="onSubmit" style="flex:2">确认提交</button>
    </view>
  </view>
</view>

<view wx:if="{{showCloseConfirm}}" class="sheet-overlay" bindtap="onCloseCloseConfirm">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">确认关单</view>
    <view class="mt-16">确定要提前结束此任务吗？</view>
    <view class="flex-row mt-16 gap-12" bindtap="onExcludeChange">
      <text>{{excludeAttendance ? '☑' : '☐'}}</text>
      <text>不计入考勤</text>
    </view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseCloseConfirm" style="flex:1">取消</button>
      <button class="btn-danger" bindtap="onConfirmClose" style="flex:2">确认关单</button>
    </view>
  </view>
</view>

<view wx:if="{{showRemoveSheet}}" class="sheet-overlay" bindtap="onCloseRemoveSheet">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">确认移除</view>
    <view class="mt-16">确定要取消此接取吗？</view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseRemoveSheet" style="flex:1">取消</button>
      <button class="btn-danger" bindtap="onCancelClaim" style="flex:2">确认</button>
    </view>
  </view>
</view>
