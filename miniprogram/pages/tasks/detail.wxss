/* 任务详情 */

.image-swiper {
  width: 100%;
  height: 400rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
}

.detail-card {
  margin-top: -20rpx;
  border-radius: 24rpx 24rpx 16rpx 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.ml-16 { margin-left: 16rpx; }
.ml-8 { margin-left: 8rpx; }

.slot-item {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.slot-time {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 接取人员 */
.claimant-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.claimant-item:last-child {
  border-bottom: none;
}
.avatar-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}
.avatar-placeholder {
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.claimant-name {
  font-size: 28rpx;
  color: #333;
}

/* 按钮 */
.btn-sm {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}
.btn-green {
  background: #52c41a;
  color: #fff;
  border: none;
}
.btn-red {
  background: #ff4d4f;
  color: #fff;
  border: none;
}
.btn-full {
  width: 100%;
}

/* 弹窗 */
.sheet-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.sheet-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16rpx;
}
.sheet-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
.sheet-actions {
  display: flex;
  gap: 20rpx;
}
.sheet-actions button {
  flex: 1;
}

/* 凭证图片 */
.evidence-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.evidence-img-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.evidence-img {
  width: 100%;
  height: 100%;
}
.evidence-remove {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.evidence-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.evidence-add-icon {
  font-size: 48rpx;
  color: #1677ff;
}

/* 审核选项 */
.review-options {
  display: flex;
  gap: 20rpx;
}
.review-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.review-active {
  border-color: #1677ff;
  background: #e6f4ff;
  color: #1677ff;
}

/* checkbox */
.checkbox {
  font-size: 32rpx;
  color: #999;
}
.checkbox.checked {
  color: #1677ff;
}
