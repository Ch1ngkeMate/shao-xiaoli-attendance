/* 任务详情 — 复刻 Web 端 */

.image-swiper { width: 100%; height: 420rpx; }
.swiper-image { width: 100%; height: 100%; }

/* ===== 标题区 ===== */
.detail-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  line-height: 1.3;
}

/* ===== 信息区 ===== */
.info-row {
  display: flex;
  padding: var(--spacing-sm) 0;
}

.info-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.info-value {
  flex: 1;
  font-size: var(--font-size-base);
  line-height: 1.5;
  word-break: break-all;
}

.slot-line { padding: 2rpx 0; }

.info-divider {
  height: 1rpx;
  background: var(--color-split);
}

/* ===== 接取人员 ===== */
.card-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.slot-claim-group {
  margin-bottom: var(--spacing-md);
}
.slot-claim-group:last-child { margin-bottom: 0; }

.slot-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.claimant-tags {
  display: flex; flex-wrap: wrap; gap: 8rpx;
}

.claimant-tag {
  display: flex; align-items: center; gap: 8rpx;
  padding: 6rpx 16rpx 6rpx 6rpx;
  background: var(--color-fill-alter);
  border: 1rpx solid var(--color-border-secondary);
  border-radius: 32rpx;
  font-size: 24rpx;
}
.claimant-tag-name { max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.remove-claimant {
  margin-left: 4rpx;
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.avatar-xs {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: var(--color-border-secondary);
}
.avatar-placeholder-xs {
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}

/* ===== 我的操作 ===== */
.claim-slot-row {
  padding: var(--spacing-sm) 0;
}
.claim-slot-row + .claim-slot-row {
  border-top: 1rpx solid var(--color-split);
}

.btn-sm-inline {
  height: 48rpx; padding: 0 20rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}
.btn-danger-inline {
  background: #ff4d4f; color: #fff;
  border: none; border-radius: 8rpx;
}

/* 审核列表 */
.review-item {
  padding: var(--spacing-sm) 0;
}
.review-item + .review-item {
  border-top: 1rpx solid var(--color-split);
}
.review-user {
  font-size: var(--font-size-base);
  font-weight: 500;
}

/* 弹窗 */
.sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex; align-items: flex-end;
}

.sheet-content {
  width: 100%;
  background: var(--color-bg-container);
  border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
  padding: var(--spacing-lg);
  max-height: 80vh;
  overflow-y: auto;
}

.sheet-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  text-align: center;
}

.sheet-textarea {
  width: 100%; min-height: 120rpx;
  padding: var(--spacing-sm);
  background: var(--color-bg-layout);
  border: 1rpx solid var(--color-border);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-base);
  box-sizing: border-box;
}

.sheet-actions {
  display: flex; gap: var(--spacing-sm);
}

/* 凭证图片 */
.evidence-images { display: flex; flex-wrap: wrap; gap: 12rpx; }
.evidence-img-sm {
  width: 120rpx; height: 120rpx;
  border-radius: var(--border-radius-sm);
}
.evidence-img-wrap {
  position: relative; width: 140rpx; height: 140rpx;
  border-radius: var(--border-radius-sm); overflow: hidden;
}
.evidence-img {
  width: 100%; height: 100%;
}
.evidence-remove {
  position: absolute; top: -2rpx; right: -2rpx;
  width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,0.55); color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
}
.evidence-add {
  width: 140rpx; height: 140rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--border-radius-sm);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.evidence-add-icon { font-size: 48rpx; color: var(--color-primary); }
