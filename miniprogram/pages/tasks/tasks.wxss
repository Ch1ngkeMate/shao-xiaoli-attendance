/* 任务大厅 — 复刻 Web 端 Ant Design */

/* 搜索栏 */
.search-bar {
  padding: var(--spacing-sm) var(--spacing-md);
}
.search-bar input {
  height: 64rpx; padding: 0 24rpx;
  background: #fff; border: 2rpx solid var(--color-border);
  border-radius: var(--border-radius-sm); font-size: var(--font-size-base);
  width: 100%; box-sizing: border-box;
}

/* 筛选标签 */
.filter-scroll {
  white-space: nowrap;
  padding: 0 var(--spacing-md) var(--spacing-sm);
}
.filter-row { display: flex; gap: 8rpx; }
.filter-tag {
  display: inline-flex; align-items: center;
  height: 52rpx; padding: 0 20rpx;
  background: #fff; color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border); border-radius: 32rpx;
  font-size: var(--font-size-sm);
}
.filter-tag-active {
  background: var(--color-primary); color: #fff;
  border-color: var(--color-primary);
}

/* 任务卡片 */
.task-list { padding-bottom: 32rpx; }

.task-card {
  background: var(--color-bg-container);
  border: 1rpx solid var(--color-border-secondary);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
}
.task-card:active { background: var(--color-fill-alter); }

.task-title {
  font-size: var(--font-size-lg); font-weight: 600;
  line-height: 1.3; flex: 1; min-width: 0;
}

.task-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.task-meta { gap: var(--spacing-sm); }

.task-time {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.task-footer {
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-split);
}

/* 发布按钮 */
.fab {
  position: fixed; right: 40rpx; bottom: 120rpx;
  width: 96rpx; height: 96rpx;
  background: var(--color-primary); color: #fff;
  border-radius: 50%; box-shadow: 0 6rpx 24rpx rgba(22,119,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: 300;
  z-index: 10;
}
