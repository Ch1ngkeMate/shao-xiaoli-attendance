/* 任务大厅 */

/* 筛选栏 */
.filter-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}
.filter-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}
.filter-tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s;
}
.filter-tag-active {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
}

/* 任务卡片 */
.task-card {
  transition: transform 0.15s;
}
.task-card:active {
  transform: scale(0.98);
  background: #fafafa;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  max-width: 70%;
}

.task-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.task-meta {
  flex-wrap: wrap;
}

.ml-16 {
  margin-left: 16rpx;
}

.task-time {
  font-size: 22rpx;
}

.task-footer {
  flex-wrap: wrap;
  gap: 16rpx;
}
