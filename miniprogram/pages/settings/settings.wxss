/* settings — 动森主题 */

.form-page { padding: 0 0 80rpx; }

.card-title {
  font-size: var(--font-size-lg); font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.form-label {
  font-size: 26rpx; color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.bg-preview {
  width: 100%; height: 160rpx;
  background-size: cover; background-position: center;
  border-radius: var(--border-radius-base); border: 1rpx solid var(--color-border);
}
.bg-preview-empty {
  background: var(--color-bg-layout);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-text-tertiary);
}
