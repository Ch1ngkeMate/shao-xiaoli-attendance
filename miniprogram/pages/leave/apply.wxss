@import "../publish/publish.wxss";
.cat-option { flex:1; text-align:center; padding:20rpx; border:2rpx solid #e8e8e8; border-radius:12rpx; font-size:28rpx; color:#666; margin-right:16rpx; }
.cat-option:last-child { margin-right:0; }
.cat-active { border-color:#1677ff; background:#e6f4ff; color:#1677ff; font-weight:600; }
.picker-value { background:#f5f5f5; border-radius:10rpx; padding:16rpx 20rpx; font-size:26rpx; color:#333; }
