/* leave/apply — 动森主题 */

.cat-option { flex:1; text-align:center; padding:20rpx; border:2rpx solid var(--color-border); border-radius:var(--border-radius); font-size:var(--font-size-sm); color:var(--color-text-secondary); margin-right:16rpx; }
.cat-option:last-child { margin-right:0; }
.cat-active { border-color:var(--color-primary); background:var(--color-primary-bg); color:var(--color-primary); font-weight:600; }
.picker-value { background:var(--color-bg-content); border-radius:var(--border-radius); padding:16rpx 20rpx; font-size:var(--font-size-sm); color:var(--color-text); }
