<wxs module="utils">
  var formatTime = function(s) {
    if (!s) return '';
    var d = getDate(s);
    var M = d.getMonth()+1, D = d.getDate(), h = d.getHours(), m = d.getMinutes();
    if (M<10) M='0'+M; if (D<10) D='0'+D;
    if (h<10) h='0'+h; if (m<10) m='0'+m;
    return M+'-'+D+' '+h+':'+m;
  };
  module.exports = { formatTime: formatTime };
</wxs>

<view wx:if="{{loading}}" class="load-more">加载中...</view>

<block wx:elif="{{meeting}}">
  <view class="card">
    <view class="meeting-title">{{meeting.title}}</view>
    <view class="flex-between mt-16">
      <view wx:if="{{meeting.endedAt}}" class="tag tag-gray">已结束</view>
      <view wx:else class="tag tag-green">进行中</view>
      <view class="hint">发布者: {{meeting.publisher ? meeting.publisher.displayName : ''}}</view>
    </view>
    <view class="mt-16 hint">🕐 {{utils.formatTime(meeting.startTime)}}</view>
    <view wx:if="{{meeting.place}}" class="mt-8 hint">📍 {{meeting.place}}</view>
    <view wx:if="{{meeting.description}}" class="mt-16 meeting-desc">{{meeting.description}}</view>
  </view>

  <!-- 参会人员 -->
  <view class="card">
    <view class="section-title">参会人员 ({{members.length}}人)</view>
    <view wx:if="{{members.length > 0}}">
      <view wx:for="{{members}}" wx:key="id" class="member-tag tag tag-blue">{{item.displayName}}</view>
    </view>
    <view wx:else class="hint">暂无</view>
  </view>

  <!-- 关会（管理员/部长，进行中的会议） -->
  <view wx:if="{{!meeting.endedAt && isAdminOrMinister}}" class="card">
    <view class="section-title">结束会议并记录考勤</view>
    <view class="hint" style="margin-bottom:16rpx;">
      勾选未到场且未准假的部员为「旷会」（每人扣 1 分）。已准假的部员已自动排除，无需勾选。若无人旷会，直接点结束。
    </view>
    <view wx:if="{{members.length > 0}}">
      <view wx:for="{{members}}" wx:key="id" class="flex-between member-check-row">
        <view class="flex-row gap-8">
          <text>{{item.displayName}}</text>
          <text wx:if="{{approvedUserIds.indexOf(item.id) >= 0}}" class="tag tag-gray tag-sm">已准假</text>
        </view>
        <view wx:if="{{approvedUserIds.indexOf(item.id) >= 0}}" class="tag tag-gray tag-sm">✔ 免记</view>
        <view wx:else data-uid="{{item.id}}" bindtap="onToggleAbsent">
          <view wx:if="{{absentUserIds.indexOf(item.id) >= 0}}" class="checkbox checked">☑</view>
          <view wx:else class="checkbox">☐</view>
        </view>
      </view>
    </view>
    <button class="btn-primary btn-full mt-16" bindtap="onOpenEndConfirm">结束会议并记录考勤</button>
  </view>

  <!-- 旷会已记录（已结束的会议） -->
  <view wx:if="{{meeting.endedAt && absences.length > 0}}" class="card">
    <view class="section-title">旷会已记录</view>
    <view wx:for="{{absences}}" wx:key="userId" class="mb-8">
      <text wx:for="{{members}}" wx:for-item="m" wx:key="id">
        <block wx:if="{{m.id === item.userId}}">{{m.displayName}}</block>
      </text>
      : {{item.amount}} 分
    </view>
  </view>

  <!-- 请假记录 -->
  <view class="card">
    <view class="section-title">请假记录</view>
    <view wx:if="{{leaves.length > 0}}">
      <view wx:for="{{leaves}}" wx:key="id" class="flex-between leave-item">
        <view>{{item.user ? item.user.displayName : ''}}</view>
        <view wx:if="{{item.status === 'APPROVED'}}" class="tag tag-green">已通过</view>
        <view wx:elif="{{item.status === 'REJECTED'}}" class="tag tag-red">已驳回</view>
        <view wx:else class="tag tag-orange">待审批</view>
      </view>
    </view>
    <view wx:else class="hint">暂无请假</view>
  </view>

  <!-- 请假按钮（MEMBER） -->
  <view wx:if="{{!meeting.endedAt && !isAdminOrMinister}}" class="card">
    <button class="btn-primary btn-full" bindtap="onApplyLeave">申请请假</button>
  </view>
</block>

<!-- 关会确认弹窗 -->
<view wx:if="{{showEndConfirm}}" class="sheet-overlay" bindtap="onCloseEndConfirm">
  <view class="sheet-content" catchtap="onSheetStop">
    <view class="sheet-title">确认结束会议</view>
    <view class="mt-16">
      将记录 <text class="error">{{absentUserIds.length}}</text> 人旷会（每人扣 1 分），其余未准假部员视为到场。已准假部员不扣分。
    </view>
    <view class="sheet-actions mt-24">
      <button class="btn-ghost" bindtap="onCloseEndConfirm" style="flex:1">取消</button>
      <button class="btn-danger" bindtap="onConfirmEnd" style="flex:2" loading="{{ending}}">确认结束</button>
    </view>
  </view>
</view>
