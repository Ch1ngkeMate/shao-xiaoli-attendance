.meeting-title { font-size: 34rpx; font-weight: 700; color: #222; }
.meeting-desc { font-size: 26rpx; color: #666; line-height: 1.7; white-space: pre-wrap; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.member-tag { display: inline-block; margin: 6rpx; }
.leave-item { padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.leave-item:last-child { border-bottom: none; }
.btn-full { width: 100%; }

/* 关会成员勾选 */
.member-check-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.member-check-row:last-child { border-bottom: none; }
.checkbox {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #ccc;
}
.checkbox.checked { color: var(--color-primary); }

/* 弹窗 */
.sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex; align-items: flex-end;
}
.sheet-content {
  width: 100%;
  background: var(--color-bg-container);
  border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
  padding: var(--spacing-lg);
  max-height: 80vh;
  overflow-y: auto;
}
.sheet-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  text-align: center;
}
.sheet-actions {
  display: flex; gap: var(--spacing-sm);
}
