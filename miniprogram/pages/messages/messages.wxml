<wxs module="utils">
  // 与 Web 端对齐的类型 Tag 颜色映射
  var typeTag = function(t) {
    if (t==='ANNOUNCEMENT') return 'tag-magenta';
    if (t==='MEETING'||t==='MEETING_NEW') return 'tag-geekblue';
    if (t==='MEETING_ABSENCE') return 'tag-red';
    if (t==='TASK'||t==='TASK_DONE') return 'tag-blue';
    if (t==='TASK_REVIEW') return 'tag-blue';
    if (t==='TASK_STALL_MEMBER'||t==='TASK_STALL_MANAGER') return 'tag-volcano';
    if (t==='LEAVE'||t==='LEAVE_APPLY') return 'tag-orange';
    if (t==='LEAVE_DECIDED') return 'tag-green';
    return 'tag-gray';
  };
  var typeLabel = function(t) {
    if (t==='ANNOUNCEMENT') return '公告';
    if (t==='MEETING'||t==='MEETING_NEW') return '会议';
    if (t==='MEETING_ABSENCE') return '旷会';
    if (t==='TASK'||t==='TASK_DONE') return '任务';
    if (t==='TASK_REVIEW') return '审核';
    if (t==='TASK_STALL_MEMBER'||t==='TASK_STALL_MANAGER') return '滞留';
    if (t==='LEAVE'||t==='LEAVE_APPLY') return '请假';
    if (t==='LEAVE_DECIDED') return '假条';
    return t;
  };
  var formatTime = function(s) {
    if (!s) return '';
    var d = getDate(s), now = getDate();
    var diff = now.getTime() - d.getTime();
    if (diff < 60000) return '刚刚';
    if (diff < 3600000) return Math.floor(diff/60000)+'分钟前';
    if (diff < 86400000) return Math.floor(diff/3600000)+'小时前';
    var M = d.getMonth()+1, D = d.getDate();
    if (M<10) M='0'+M; if (D<10) D='0'+D;
    return M+'-'+D;
  };
  module.exports = { typeTag:typeTag, typeLabel:typeLabel, formatTime:formatTime };
</wxs>

<view class="msg-header flex-between">
  <view class="msg-title">消息 ({{unreadCount}}条未读)</view>
  <view wx:if="{{unreadCount > 0}}" class="mark-all-read" bindtap="onMarkAllRead">全部已读</view>
</view>

<view wx:if="{{messages.length > 0}}">
  <view
    wx:for="{{messages}}"
    wx:key="id"
    class="msg-item"
    style="{{!item.read ? 'background:rgba(0,0,0,0.02);' : ''}}"
    data-item="{{item}}"
    bindtap="onMessageTap"
  >
    <view class="flex-between">
      <view class="flex-row gap-8">
        <view class="tag {{utils.typeTag(item.type)}}">{{utils.typeLabel(item.type)}}</view>
        <view class="msg-item-title ellipsis">{{item.title}}</view>
      </view>
      <view class="flex-row gap-8">
        <view wx:if="{{!item.read}}" class="unread-dot"></view>
        <view class="msg-item-time hint">{{utils.formatTime(item.createdAt)}}</view>
      </view>
    </view>
    <view class="msg-item-body ellipsis-2 mt-8">{{item.body}}</view>
  </view>

  <view class="load-more">— 已加载全部 —</view>
  <divider type="brown" height="24" />
</view>

<view wx:elif="{{!loading}}" class="empty">
  <image class="empty-img" src="/assets/empty-messages.png" mode="aspectFit" />
  <view class="empty-text">暂无消息</view>
</view>

<!-- 加载中 -->
<view wx:if="{{loading}}" class="empty">
  <view class="leaf-spin">🍃</view>
  <view class="empty-text">加载中...</view>
</view>

<!-- 发布公告 FAB（MINISTER/ADMIN） -->
<view wx:if="{{showFab}}" class="fab" bindtap="onPublishAnnouncement">
  <icon name="chat" size="48" />
</view>
