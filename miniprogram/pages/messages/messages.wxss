/* 消息 — 对齐 Web 端 */

.msg-header {
  padding: var(--spacing-md) var(--spacing-md) var(--spacing-sm);
}
.msg-title { font-size: var(--font-size-lg); font-weight: 600; }
.mark-all-read { font-size: var(--font-size-sm); color: var(--color-primary); }

.msg-item {
  background: var(--color-bg-container);
  margin: 8rpx var(--spacing-md);
  padding: var(--spacing-md);
  border-radius: var(--border-radius);
  border: 1rpx solid var(--color-border-secondary);
}
.msg-item-title { font-size: var(--font-size-base); font-weight: 500; flex: 1; min-width: 0; }
.msg-item-body { font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height: 1.5; }
.msg-item-time { font-size: 22rpx; white-space: nowrap; }

.unread-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}

/* 发布公告 FAB — 与任务页一致 */
.fab {
  position: fixed; right: 40rpx; bottom: 120rpx;
  width: 96rpx; height: 96rpx;
  background: var(--color-primary); color: #fff;
  border-radius: 50%; box-shadow: 0 6rpx 24rpx rgba(22,119,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: 300;
  z-index: 10;
}
