/* 消息列表 */

.msg-header {
  padding: 20rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.msg-title {
  font-size: 30rpx;
  font-weight: 600;
}
.mark-all-read {
  color: #1677ff;
  font-size: 26rpx;
}

.msg-item {
  padding: 24rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}
.msg-item:active {
  background: #fafafa;
}

.msg-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ml-16 { margin-left: 16rpx; }

.msg-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  max-width: 85%;
}

.msg-item-body {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.msg-item-time {
  font-size: 22rpx;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  background: #ff4d4f;
  border-radius: 50%;
  flex-shrink: 0;
}
