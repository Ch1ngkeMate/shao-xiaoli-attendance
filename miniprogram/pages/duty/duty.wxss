/* Tab切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 50;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text);
  border-bottom: 4rpx solid transparent;
}
.tab-active {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
  font-weight: 600;
}
.tab-content {
  padding-bottom: 60rpx;
}

/* 值班表 — 课程表样式 */
.duty-table {
  margin: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-border-light);
}
.duty-header {
  display: flex;
  background: #f0f5ff;
  border-bottom: 1rpx solid #d6e4ff;
}
.duty-row {
  display: flex;
}
.duty-row + .duty-row {
  border-top: 1rpx solid var(--color-bg-secondary);
}
.duty-cell {
  flex: 1;
  padding: 8rpx 4rpx;
  text-align: center;
  font-size: 22rpx;
  min-height: 120rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  align-content: center;
  gap: 4rpx;
  border-right: 1rpx solid #f0f0f0;
  box-sizing: border-box;
  position: relative;
}
.duty-cell:last-child {
  border-right: none;
}
.duty-label {
  max-width: 70rpx;
  min-width: 70rpx;
  flex: 0 0 70rpx;
  font-weight: 600;
  color: var(--color-text);
  font-size: 24rpx;
  background: var(--color-bg-container);
  border-right: 1rpx solid var(--color-border-light);
}
.duty-header-cell {
  font-weight: 600;
  color: var(--color-primary);
  font-size: 24rpx;
  min-height: 64rpx;
}
.duty-data-cell {
  flex-direction: column;
}
.duty-names {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
  width: 100%;
}
.duty-name-tag {
  margin: 1rpx;
  font-size: 20rpx;
  padding: 2rpx 6rpx;
  line-height: 1.3;
}

/* 值班编辑 */
.duty-name-row {
  display: flex;
  align-items: center;
  gap: 2rpx;
}
.duty-remove {
  font-size: 24rpx;
  color: var(--color-error);
  padding: 4rpx 12rpx;
  flex-shrink: 0;
  line-height: 1;
}
.duty-add {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: var(--color-primary);
  padding: 2rpx 8rpx;
  border: 1rpx dashed #91caff;
  border-radius: 6rpx;
  text-align: center;
  width: 100%;
}

/* 添加值班弹窗 */
.duty-sheet-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.duty-sheet {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
}
.duty-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.duty-sheet-title {
  font-size: 32rpx; font-weight: 700;
}
.duty-sheet-close {
  font-size: 36rpx; color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}
.duty-sheet-body {
  padding-bottom: 24rpx;
}
.duty-select {
  color: #333;
  display: flex;
  align-items: center;
}
.duty-select.hint { color: var(--color-text-secondary); }

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.btn-full { width: 100%; }

/* 会议卡片 */
.meeting-title { font-size: 30rpx; font-weight: 600; max-width: 70%; }

/* 请假 */
.leave-type { font-size: 28rpx; font-weight: 600; }
.leave-reason { font-size: 26rpx; color: var(--color-text); }

/* 统计 */
.stat-name { font-size: 28rpx; font-weight: 600; }
.stat-points { font-size: 26rpx; }
.stat-detail { gap: 24rpx; }
.stat-item { font-size: 24rpx; color: #888; }
.stat-card:active { background: var(--color-bg-container); }

/* ====== 请假审批弹窗 ====== */
.leave-sheet-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.leave-sheet {
  width: 100%;
  max-height: 85vh;
  background: #e8e0d5;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 32rpx 48rpx;
  overflow-y: auto;
  box-sizing: border-box;
}
.leave-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(92,64,51,0.15);
  margin-bottom: 20rpx;
}
.leave-sheet-title {
  font-size: 32rpx; font-weight: 700;
  color: #2c1f14;
  letter-spacing: 0.3em;
}
.leave-sheet-close {
  font-size: 36rpx; color: #5c4033;
  padding: 8rpx 16rpx;
  line-height: 1;
}

/* 纸质请假条 */
.leave-paper {
  background: linear-gradient(165deg, #faf6ef 0%, #ede4d3 48%, #f5f0e6 100%);
  border: 4rpx solid #5c4033;
  border-radius: 4rpx;
  box-shadow: inset 0 0 48rpx rgba(92,64,51,0.08), 0 4rpx 24rpx rgba(0,0,0,0.06);
  padding: 48rpx 48rpx 56rpx;
  color: #3d2914;
  font-size: 28rpx;
  line-height: 1.85;
  position: relative;
  margin-bottom: 24rpx;
}
.leave-paper-inner {
  position: relative;
  z-index: 1;
}
.leave-paper-border {
  position: absolute;
  inset: -12rpx;
  border: 2rpx solid rgba(92,64,51,0.25);
  border-radius: 2rpx;
  pointer-events: none;
}
.leave-paper-title {
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0.35em;
  color: #2c1f14;
  margin-bottom: 28rpx;
}
.leave-paper-body {
  margin-bottom: 12rpx;
}
.leave-underline {
  border-bottom: 2rpx solid rgba(61,43,31,0.45);
  padding: 0 4rpx 2rpx;
  font-weight: 600;
}

/* 操作按钮 */
.leave-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  flex-wrap: wrap;
  padding: 20rpx 0;
}
.btn-leave-approve {
  width: 180rpx; height: 80rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-active));
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 12rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  line-height: 80rpx;
}
.btn-leave-approve.btn-danger {
  background: linear-gradient(135deg, var(--color-error), var(--color-error-active));
}
.btn-leave-reject {
  width: 180rpx; height: 80rpx;
  background: #fff;
  color: var(--color-error); font-size: 30rpx; font-weight: 600;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-error);
  display: flex; align-items: center; justify-content: center;
  line-height: 80rpx;
}
.btn-leave-close {
  width: 180rpx; height: 80rpx;
  background: #fff;
  color: var(--color-text); font-size: 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
  display: flex; align-items: center; justify-content: center;
  line-height: 80rpx;
}

/* 驳回输入区 */
.leave-reject-area {
  padding: 20rpx 0 40rpx;
}
.leave-reject-input {
  width: 100%;
  min-height: 160rpx;
  background: #fff;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.leave-reject-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  flex-wrap: wrap;
}
