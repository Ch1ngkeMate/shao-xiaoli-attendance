/* ============================================
 * 考勤页 — Animal Island 动森主题
 * ============================================ */

/* ===== Tab 切换 ===== */
.tab-bar {
  display: flex;
  background: var(--color-bg);
  padding: 16rpx 32rpx;
  gap: 12rpx;
  position: sticky;
  top: 0;
  z-index: 50;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-muted);
  background: transparent;
  border-radius: 100rpx;
  transition: all var(--motion-base) var(--motion-ease);
  letter-spacing: 0.02em;
}
.tab-active {
  color: var(--color-primary);
  background: rgba(25, 200, 185, 0.15);
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  transform: translateY(-2rpx);
}
.tab-content {
  padding: 0 16rpx 60rpx;
  animation: anisland-fadeup 0.3s ease;
}

/* ===== 值班表 — 日历卡片风格 ===== */
.duty-table {
  background: var(--color-bg-content);
  border-radius: 40rpx;
  margin: 20rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(107, 92, 67, 0.42);
}

/* 表头行 */
.duty-header {
  display: flex;
  background: var(--color-primary-bg);
  border-bottom: 4rpx solid var(--color-primary);
}
.duty-row {
  display: flex;
}
.duty-row + .duty-row {
  border-top: 3rpx solid var(--color-border-light);
  border-top-style: dashed;
}

/* 单元格 */
.duty-cell {
  flex: 1;
  padding: 12rpx 6rpx;
  text-align: center;
  font-size: 22rpx;
  min-height: 120rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  align-content: center;
  gap: 6rpx;
  border-right: 2rpx dashed var(--color-border-light);
  box-sizing: border-box;
  position: relative;
  transition: background var(--motion-fast);
}
.duty-cell:last-child { border-right: none; }

/* 周几标签列 */
.duty-label {
  max-width: 80rpx; min-width: 80rpx;
  flex: 0 0 80rpx;
  font-weight: 700;
  font-size: 26rpx;
  color: var(--color-text);
  background: var(--color-bg-secondary);
  border-right: 3rpx solid var(--color-border-light);
  letter-spacing: 0.03em;
}

/* 表头（第1节~第5节）*/
.duty-header-cell {
  font-weight: 700;
  font-size: 24rpx;
  color: var(--color-primary-active);
  min-height: 64rpx;
  letter-spacing: 0.02em;
}

/* 数据格 */
.duty-data-cell {
  flex-direction: column;
}

/* 值班姓名的 pill 标签 */
.duty-names {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
  width: 100%;
}
.duty-name-tag {
  margin: 2rpx;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  line-height: 1.3;
  border-radius: 100rpx !important;
  font-weight: 600;
}

/* 编辑：人名行 */
.duty-name-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* ✕ 删除按钮 — pill 风格 */
.duty-remove {
  width: 36rpx; height: 36rpx;
  font-size: 22rpx; font-weight: 700;
  color: #fff;
  background: var(--color-error);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 0 0 var(--color-error-active);
  line-height: 1;
}
.duty-remove:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 0 0 var(--color-error-active);
}

/* + 加人按钮 — 虚线 pill */
.duty-add {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 3rpx dashed var(--color-primary);
  border-radius: 100rpx;
  text-align: center;
  width: auto;
  letter-spacing: 0.02em;
  transition: all var(--motion-fast);
}
.duty-add:active {
  background: var(--color-primary-bg);
  border-style: solid;
  transform: scale(0.95);
}

/* ===== 添加值班弹窗 ===== */
.duty-sheet-mask {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: anisland-fadein var(--motion-base) ease;
}
.duty-sheet {
  width: 100%;
  background: var(--color-bg-content);
  border-radius: 64rpx 64rpx 0 0;
  padding: 48rpx 48rpx 48rpx;
  box-sizing: border-box;
  animation: anisland-zoomin 0.3s ease;
  box-shadow: 0 -16rpx 48rpx rgba(61, 52, 40, 0.14);
}
.duty-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 3rpx solid var(--color-border-light);
  margin-bottom: 32rpx;
}
.duty-sheet-title {
  font-size: 36rpx; font-weight: 700;
  color: var(--color-text);
}
.duty-sheet-close {
  width: 56rpx; height: 56rpx;
  font-size: 32rpx; font-weight: 700;
  color: var(--color-text-secondary);
  background: transparent;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: all var(--motion-fast);
}
.duty-sheet-close:active {
  background: rgba(114, 93, 66, 0.1);
  color: var(--color-text);
}
.duty-sheet-body {
  padding-bottom: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* 表单标签 */
.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-body);
  margin-bottom: 12rpx;
  letter-spacing: 0.02em;
}

/* 表单输入/选择 */
.form-input {
  height: 80rpx;
  padding: 0 32rpx;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 0.01em;
  color: var(--color-text-body);
  background: var(--color-bg-input);
  border: 5rpx solid var(--color-border-light);
  border-radius: 100rpx;
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  box-sizing: border-box;
  display: flex; align-items: center;
}
.form-input:focus {
  border-color: var(--color-focus-yellow);
  box-shadow: 0 6rpx 0 0 var(--color-focus-yellow-d),
              0 0 0 6rpx rgba(255, 204, 0, 0.15);
}

/* 弹窗内确认按钮 */
.duty-sheet-body .btn-primary {
  margin-top: 32rpx;
}

/* ===== 会议卡片 ===== */
.meeting-title {
  font-size: 30rpx; font-weight: 700;
  max-width: 70%;
  color: var(--color-text);
}

/* ===== 请假卡片 ===== */
.leave-type {
  font-size: 28rpx; font-weight: 700;
  color: var(--color-text);
}
.leave-reason {
  font-size: 26rpx; color: var(--color-text-body);
}

/* ===== 统计卡片 ===== */
.stat-name {
  font-size: 28rpx; font-weight: 700;
  color: var(--color-text);
}
.stat-points {
  font-size: 28rpx; font-weight: 700;
}
.stat-detail { gap: 24rpx; }
.stat-item {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}
.stat-card:active {
  transform: translateY(-6rpx);
  background: var(--color-bg-content) !important;
}

/* ===== 叶子装饰 ===== */
.leaf-decor {
  display: inline-block;
  font-size: 32rpx;
  opacity: 0.6;
  margin: 0 8rpx;
  animation: leaf-wiggle 3s ease-in-out infinite;
}
@keyframes leaf-wiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-8deg) scale(1.05); }
  75% { transform: rotate(8deg) scale(1.05); }
}

/* ===== 动森装饰元素 ===== */
.ac-decor {
  font-size: 40rpx;
  filter: drop-shadow(0 4rpx 4rpx rgba(61, 52, 40, 0.15));
}

/* 小动物硅质 — 可以放在卡片标题旁 */
.ac-critter {
  font-size: 44rpx;
  animation: anisland-fadeup 0.5s ease-out;
}

/* ===== 请假审批弹窗 — 纸质请假条 ===== */
.leave-sheet-mask {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: anisland-fadein var(--motion-base) ease;
}
.leave-sheet {
  width: 100%;
  max-height: 85vh;
  background: var(--color-bg-content);
  border-radius: 64rpx 64rpx 0 0;
  padding: 0 48rpx 48rpx;
  overflow-y: auto;
  box-sizing: border-box;
  animation: anisland-slideup 0.3s ease;
  box-shadow: 0 -16rpx 48rpx rgba(61, 52, 40, 0.14);
}
.leave-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 24rpx;
  border-bottom: 3rpx solid var(--color-border-light);
  margin-bottom: 32rpx;
}
.leave-sheet-title {
  font-size: 36rpx; font-weight: 700;
  color: var(--color-text);
  letter-spacing: 0.05em;
}
.leave-sheet-close {
  width: 56rpx; height: 56rpx;
  font-size: 32rpx; font-weight: 700;
  color: var(--color-text-secondary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.leave-sheet-close:active {
  background: rgba(114, 93, 66, 0.1);
}

/* 请假条纸面 */
.leave-paper {
  background: linear-gradient(165deg, #faf6ef 0%, #ede4d3 48%, #f5f0e6 100%);
  border: 6rpx solid #5c4033;
  border-radius: 4rpx;
  box-shadow:
    inset 0 0 48rpx rgba(92, 64, 51, 0.08),
    0 8rpx 20rpx rgba(107, 92, 67, 0.42);
  padding: 48rpx 48rpx 56rpx;
  color: #3d2914;
  font-size: 28rpx;
  line-height: 1.85;
  position: relative;
  margin-bottom: 32rpx;
  font-family: var(--animal-font);
}
.leave-paper-inner {
  position: relative;
  z-index: 1;
}
.leave-paper-border {
  position: absolute;
  inset: -12rpx;
  border: 3rpx solid rgba(92, 64, 51, 0.25);
  border-radius: 2rpx;
  pointer-events: none;
}
.leave-paper-title {
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0.35em;
  color: #2c1f14;
  margin-bottom: 28rpx;
}
.leave-paper-body {
  margin-bottom: 12rpx;
}
.leave-underline {
  border-bottom: 3rpx solid rgba(61, 43, 31, 0.45);
  padding: 0 4rpx 2rpx;
  font-weight: 600;
}

/* 请假操作按钮 — 3D pill */
.leave-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  padding: 8rpx 0;
}
.btn-leave-approve {
  height: 90rpx; padding: 0 48rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-bg);
  color: var(--color-text);
  border: 2px solid var(--color-bg);
  box-shadow: 0 10rpx 0 0 var(--color-shadow-btn);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-leave-approve:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 var(--color-shadow-btn);
}
.btn-leave-approve.btn-danger {
  background: var(--color-error);
  color: #fff;
  box-shadow: 0 10rpx 0 0 var(--color-error-active);
}
.btn-leave-approve.btn-danger:active {
  box-shadow: 0 2rpx 0 0 var(--color-error-active);
}
.btn-leave-reject {
  height: 90rpx; padding: 0 48rpx;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 0.02em; line-height: 1;
  border-radius: 100rpx;
  background: var(--color-bg-content);
  color: var(--color-error);
  border: 5rpx solid var(--color-error);
  box-shadow: 0 10rpx 0 0 var(--color-shadow-input);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-leave-reject:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 0 var(--color-shadow-input);
}
.btn-leave-close {
  height: 90rpx; padding: 0 48rpx;
  font-size: 28rpx; font-weight: 600;
  border-radius: 100rpx;
  background: var(--color-bg-content);
  color: var(--color-text-body);
  border: 5rpx solid var(--color-border-light);
  box-shadow: 0 6rpx 0 0 var(--color-shadow-input);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--motion-base) var(--motion-ease);
}
.btn-leave-close:active {
  transform: translateY(4rpx);
}

/* 驳回输入 */
.leave-reject-area {
  padding: 8rpx 0 16rpx;
}
.leave-reject-input {
  width: 100%; min-height: 160rpx;
  background: var(--color-bg-input);
  border: 5rpx solid var(--color-border-light);
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  color: var(--color-text-body);
}
.leave-reject-input:focus {
  border-color: var(--color-focus-yellow);
  box-shadow: 0 0 0 6rpx rgba(255, 204, 0, 0.15);
}
.leave-reject-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

/* ===== 全局动画（duty 页面独有）===== */
@keyframes anisland-fadein {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes anisland-zoomin {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes anisland-fadeup {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes anisland-slideup {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* picker-view 内嵌标签 */
.duty-select {
  display: flex; align-items: center;
  min-height: 72rpx; padding: 0 28rpx;
  color: var(--color-text-disabled);
  font-size: 26rpx;
  background: var(--color-bg-content);
  border-radius: 100rpx;
  border: 2.5px solid var(--color-border-light);
}
.duty-picker-label {
  display: flex; align-items: center;
  min-height: 72rpx; padding: 0 28rpx;
  color: var(--color-text);
  font-size: 28rpx; font-weight: 600;
  background: var(--color-primary-bg);
  border-radius: 100rpx;
  border: 2.5px solid var(--color-primary);
  white-space: nowrap;
}

/* ===== 工具间距 ===== */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 24rpx; }
.mt-24 { margin-top: 32rpx; }
.btn-full { width: 100%; }
