<wxs module="utils">
  var weeks = ['周一','周二','周三','周四','周五'];
  var periods = ['第1节','第2节','第3节','第4节','第5节'];
  var formatTime = function(s) {
    if (!s) return '';
    var d = getDate(s);
    var M = d.getMonth()+1, D = d.getDate(), h = d.getHours(), m = d.getMinutes();
    if (M<10) M='0'+M; if (D<10) D='0'+D;
    if (h<10) h='0'+h; if (m<10) m='0'+m;
    return M+'-'+D+' '+h+':'+m;
  };
  var leaveStatus = function(s) {
    if (s === 'PENDING') return '待审批';
    if (s === 'APPROVED') return '已通过';
    if (s === 'REJECTED') return '已驳回';
    return s;
  };
  var leaveTagClass = function(s) {
    if (s === 'APPROVED') return 'tag-green';
    if (s === 'REJECTED') return 'tag-red';
    return 'tag-orange';
  };
  module.exports = { weeks:weeks, periods:periods, formatTime:formatTime, leaveStatus:leaveStatus, leaveTagClass:leaveTagClass };
</wxs>

<!-- Tab 切换 -->
<view class="tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="*this"
    class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
    data-index="{{index}}"
    bindtap="onTabChange"
  >{{item}}</view>
</view>

<!-- ====== 值班表 Tab ====== -->
<view wx:if="{{activeTab === 0}}" class="tab-content">
  <view class="flex-row" style="padding: 20rpx 32rpx 0;">
    <view class="leaf-decor">🍃</view>
    <view class="card-title" style="margin:0 0 0 8rpx;">值班表</view>
  </view>
  <view wx:if="{{dutyLoading}}" class="empty">
    <view class="leaf-spin">🍃</view>
    <view class="empty-text">加载中...</view>
  </view>
  <view wx:else class="duty-table">
    <view class="duty-header">
      <view class="duty-cell duty-label"></view>
      <view wx:for="{{utils.periods}}" wx:key="*this" class="duty-cell duty-header-cell">{{item}}</view>
    </view>
    <view wx:for="{{dutyGrid}}" wx:key="index" class="duty-row">
      <view class="duty-cell duty-label">{{utils.weeks[index]}}</view>
      <view wx:for="{{item}}" wx:for-item="slot" wx:for-index="pi" wx:key="pi" class="duty-cell duty-data-cell">
        <view wx:if="{{slot && slot.length > 0}}" class="duty-names">
          <view wx:for="{{slot}}" wx:for-item="u" wx:key="aid" class="duty-name-row">
            <view class="tag tag-blue duty-name-tag">{{u.displayName}}<text wx:if="{{u.deptLabel}}">({{u.deptLabel}})</text></view>
            <view wx:if="{{isAdmin}}" class="duty-remove" data-aid="{{u.aid}}" bindtap="onRemoveTap">✕</view>
          </view>
        </view>
        <view wx:else class="hint">-</view>
        <view wx:if="{{isAdmin}}" class="duty-add" data-w="{{index}}" data-p="{{pi}}" bindtap="onAddTap">+ 加人</view>
      </view>
    </view>
  </view>

  <!-- 添加值班弹窗 -->
  <view wx:if="{{showDutySheet}}" class="duty-sheet-mask" bindtap="onCloseDutySheet" catchtouchmove="noop">
    <view class="duty-sheet" catchtap="noop">
      <view class="duty-sheet-header">
        <view class="duty-sheet-title">添加值班 — {{utils.weeks[dutyPick.w]}}{{utils.periods[dutyPick.p]}}</view>
        <view class="duty-sheet-close" bindtap="onCloseDutySheet">✕</view>
      </view>
      <view class="duty-sheet-body">
        <view class="form-label">选择干事</view>
        <picker wx:if="{{assignableUsers.length > 0}}" mode="selector" range="{{assignableUsers}}" range-key="displayName" value="{{dutyUserIndex}}" bindchange="onDutyUserChange">
          <view class="form-input duty-select">
            {{dutyUserIndex >= 0 ? assignableUsers[dutyUserIndex].displayName : '请选择干事'}}
          </view>
        </picker>
        <view wx:else class="form-input duty-select hint">加载中...</view>
        <view class="form-label mt-16">部门/分组（选填）</view>
        <input class="form-input" placeholder="如 办公室、宣传部" value="{{dutyDeptLabel}}" bindinput="onDutyDeptLabelInput" maxlength="50" />
        <button class="btn-primary btn-full mt-24 anisland-btn-pill" bindtap="onConfirmAdd">确认添加</button>
      </view>
    </view>
  </view>
</view>

<!-- ====== 会议 Tab ====== -->
<view wx:if="{{activeTab === 1}}" class="tab-content">
  <view class="flex-row" style="padding: 20rpx 32rpx 0;justify-content:space-between;">
    <view class="flex-row">
      <view class="leaf-decor">📋</view>
      <view class="card-title" style="margin:0 0 0 8rpx;">会议列表</view>
    </view>
    <view wx:if="{{isAdmin}}" class="btn-primary btn-sm" bindtap="onAddMeeting" style="height:60rpx;padding:0 24rpx;font-size:24rpx;display:flex;align-items:center;gap:8rpx;">
        <icon name="design" size="32" /> 发布
      </view>
  </view>
  <view wx:if="{{meetingsLoading}}" class="empty">
    <view class="leaf-spin">🍃</view>
    <view class="empty-text">加载中...</view>
  </view>
  <block wx:elif="{{meetings.length > 0}}">
    <view wx:for="{{meetings}}" wx:key="id" class="card meeting-card" data-id="{{item.id}}" bindtap="onMeetingTap">
      <view class="flex-between">
        <view class="meeting-title ellipsis">{{item.title}}</view>
        <view wx:if="{{item.endedAt}}" class="tag tag-gray">已结束</view>
        <view wx:else class="tag tag-green">进行中</view>
      </view>
      <view class="hint mt-8">{{utils.formatTime(item.startTime)}}</view>
      <view wx:if="{{item.place}}" class="hint mt-8">📍 {{item.place}}</view>
    </view>
    <view class="load-more">— 已加载全部 —</view>
    <divider type="brown" height="24" />
  </block>
  <view wx:else class="empty">
    <image class="empty-img" src="/assets/empty-duty.webp" mode="aspectFit" />
    <view class="empty-text">暂无会议</view>
  </view>
</view>

<!-- ====== 请假 Tab ====== -->
<view wx:if="{{activeTab === 2}}" class="tab-content">
  <button wx:if="{{!isAdmin}}" class="btn-primary" style="margin:20rpx 32rpx;" bindtap="onApplyLeave">申请请假</button>
  <view wx:if="{{leavesLoading}}" class="empty">
    <view class="leaf-spin">🍃</view>
    <view class="empty-text">加载中...</view>
  </view>
  <block wx:elif="{{leaves.length > 0}}">
    <view wx:for="{{leaves}}" wx:key="id" class="card leave-card" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="onLeaveTap">
      <view class="flex-between">
        <view class="leave-type">{{item.category === 'DUTY' ? '值班请假' : '会议请假'}}</view>
        <view class="tag {{utils.leaveTagClass(item.status)}}">{{utils.leaveStatus(item.status)}}</view>
      </view>
      <view wx:if="{{item.meeting}}" class="hint mt-8">{{item.meeting.title}}</view>
      <view class="leave-reason mt-8">{{item.reason}}</view>
      <view class="hint mt-8">{{utils.formatTime(item.createdAt)}}</view>
    </view>
    <view class="load-more">— 已加载全部 —</view>
    <divider type="brown" height="24" />
  </block>
  <view wx:else class="empty">
    <image class="empty-img" src="/assets/empty-duty.webp" mode="aspectFit" />
    <view class="empty-text">暂无请假记录</view>
  </view>
</view>

<!-- ====== 统计 Tab ====== -->
<view wx:if="{{activeTab === 3 && showStats}}" class="tab-content">
  <view wx:if="{{statsLoading}}" class="empty">
    <view class="leaf-spin">🍃</view>
    <view class="empty-text">加载中...</view>
  </view>
  <block wx:elif="{{stats}}">
    <view class="card stat-card" wx:for="{{stats}}" wx:key="userId" wx:for-item="row" data-user-id="{{row.userId}}" bindtap="onStatTap">
      <view class="flex-between">
        <view class="stat-name">{{row.displayName || row.userId}}</view>
        <view class="stat-points tag tag-blue">+{{row.totalPoints || 0}}分</view>
      </view>
      <view class="flex-row mt-16 stat-detail">
        <view class="stat-item">接取 {{row.claimCount || 0}}</view>
        <view class="stat-item">提交 {{row.submitCount || 0}}</view>
        <view class="stat-item">完成 {{row.approvedCount || 0}}</view>
      </view>
    </view>
    <view class="load-more">— {{currentMonth}} 考勤统计 —</view>
  </block>
  <view wx:else class="empty">
    <image class="empty-img" src="/assets/empty-duty.webp" mode="aspectFit" />
    <view class="empty-text">暂无统计数据</view>
  </view>
</view>

<!-- ====== 请假审批弹窗 — 对齐 Web LeaveSlipModal ====== -->
<view wx:if="{{showLeaveSheet}}" class="leave-sheet-mask" bindtap="onCloseLeaveSheet" catchtouchmove="noop">
  <view class="leave-sheet" catchtap="noop">
    <view class="leave-sheet-header">
      <view class="leave-sheet-title">请假条</view>
      <view class="leave-sheet-close" bindtap="onCloseLeaveSheet">✕</view>
    </view>

    <!-- 请假条纸面 -->
    <view class="leave-paper">
      <view class="leave-paper-inner">
        <view class="leave-paper-border"></view>
        <view class="leave-paper-title">请假条</view>
        <view class="leave-paper-body">
          <text>亲爱的部长：</text>
        </view>
        <view class="leave-paper-body" style="text-indent:2em;text-align:justify;">
          我因<text class="leave-underline">{{leaveSlip.reason}}</text>
          无法参与<text class="leave-underline">{{leaveSlip.timeStr}}</text>
          的<text class="leave-underline">{{leaveSlip.eventStr}}</text>
          ，需要请假一次。特书此假条，还望批准。
        </view>
        <view class="leave-paper-body mt-16">请假人：{{leaveSlip.applicant}}</view>
        <view class="leave-paper-body">日期：{{leaveSlip.dateStr}}</view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view wx:if="{{!rejectPhase}}" class="leave-actions">
      <button class="btn-leave-approve" loading="{{leaveSubmitting}}" bindtap="onApproveLeave">同意</button>
      <button class="btn-leave-reject" disabled="{{leaveSubmitting}}" bindtap="onRejectLeave">驳回</button>
      <button class="btn-leave-close" disabled="{{leaveSubmitting}}" bindtap="onCloseLeaveSheet">关闭</button>
    </view>

    <!-- 驳回原因输入 -->
    <view wx:else class="leave-reject-area">
      <textarea
        class="leave-reject-input"
        placeholder="驳回说明（可空，将通知部员）"
        value="{{rejectReason}}"
        bindinput="onRejectReasonInput"
        maxlength="500"
        auto-height
      />
      <view class="leave-reject-actions">
        <button class="btn-leave-approve btn-danger" loading="{{leaveSubmitting}}" bindtap="onConfirmReject">确认驳回</button>
        <button class="btn-leave-close" disabled="{{leaveSubmitting}}" bindtap="onCancelReject">返回</button>
      </view>
    </view>
  </view>
</view>

<!-- ====== 发布会议弹窗 ====== -->
<view wx:if="{{showMeetingSheet}}" class="duty-sheet-mask" bindtap="onCloseMeetingSheet" catchtouchmove="noop">
  <view class="duty-sheet" catchtap="noop">
    <view class="duty-sheet-header">
      <view class="duty-sheet-title">发布会议</view>
      <view class="duty-sheet-close" bindtap="onCloseMeetingSheet">✕</view>
    </view>
    <view class="duty-sheet-body">
      <view class="form-label">会议主题</view>
      <input class="form-input" placeholder="请输入会议主题" value="{{meetingTitle}}" bindinput="onMeetingTitleInput" maxlength="200" />
      <view class="form-label mt-16">开始时间</view>
      <picker mode="multiSelector" range="{{dateTimeRange}}" value="{{meetingStartIdx}}" bindchange="onMeetingStartChange">
        <view class="form-input duty-select">{{meetingStartLabel || '请选择开始时间'}}</view>
      </picker>
      <view class="form-label mt-16">结束时间（选填）</view>
      <picker mode="multiSelector" range="{{dateTimeRange}}" value="{{meetingEndIdx}}" bindchange="onMeetingEndChange">
        <view class="form-input duty-select">{{meetingEndLabel || '请选择结束时间'}}</view>
      </picker>
      <view class="form-label mt-16">地点（选填）</view>
      <input class="form-input" placeholder="如 会议室A" value="{{meetingPlace}}" bindinput="onMeetingPlaceInput" maxlength="100" />
      <view class="form-label mt-16">说明（选填）</view>
      <textarea class="form-textarea" placeholder="会议议程或备注..." value="{{meetingDesc}}" bindinput="onMeetingDescInput" maxlength="1000" />
      <button class="btn-primary btn-full mt-24" bindtap="onConfirmMeeting">确认发布</button>
    </view>
  </view>

  <footer-sea />
</view>

<!-- ====== 移除值班确认弹窗 ====== -->
<view wx:if="{{showDutyRemoveConfirm}}" class="modal-mask" bindtap="cancelDutyRemove" catchtouchmove="noop">
  <view class="modal-card" catchtap="noop">
    <view class="modal-title">移除值班</view>
    <view class="modal-body-text">确定移除该干事的值班安排吗？</view>
    <view class="modal-actions">
      <button class="btn btn-ghost" bindtap="cancelDutyRemove">取消</button>
      <button class="btn btn-confirm-yellow" bindtap="confirmRemoveDuty" data-aid="{{dutyRemoveAid}}">确定移除</button>
    </view>
  </view>
</view>
