// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  MINISTER
  MEMBER
}

enum TaskStatus {
  OPEN
  CLOSED
}

enum ClaimStatus {
  CLAIMED
  CANCELLED
}

enum ReviewResult {
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  username     String   @unique
  displayName  String
  passwordHash String
  // 头像：本地上传 /uploads/avatar/... 或 Blob 的 https URL
  avatarUrl    String?
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true)

  tasksPublished       Task[]             @relation("TaskPublisher")
  claims                 TaskClaim[]
  submissions          TaskSubmission[]
  reviews                TaskReview[]       @relation("TaskReviewer")
  dutyAssignments        DutyAssignment[]
  leaveRequests          LeaveRequest[]     @relation("LeaveUser")
  leaveDecisions         LeaveRequest[]     @relation("LeaveDecider")
  meetingsPublished      Meeting[]          @relation("MeetingPublisher")
  inAppMessages          InAppMessage[]
  attendanceAdjusts      AttendanceAdjust[]
  meetingAbsencesRecorded Meeting[]         @relation("MeetingRecorder")
  announcementsCreated   Announcement[]
  announcementPopupsShown AnnouncementPopupShown[]
}

// --- 值班表：周一=0..周五=4，第一节=0..第五节=4，每个格子可安排多人 ---
model DutyAssignment {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  /// 0=周一 … 4=周五
  weekday    Int
  /// 0=第一节 … 4=第五节
  period     Int
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 如「办公室」，展示为「姓名（部门）」
  deptLabel  String?

  @@index([weekday, period])
  @@index([userId])
}

enum MeetingStatus {
  OPEN
  ENDED
}

model Meeting {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  title       String
  startTime   DateTime
  endTime     DateTime?
  place       String?
  description String? @db.Text
  status      MeetingStatus @default(OPEN)
  publishedBy String
  publisher   User          @relation("MeetingPublisher", fields: [publishedBy], references: [id])
  endedAt     DateTime?
  /// 由谁操作结束
  endedBy     String?
  endRecorder User?         @relation("MeetingRecorder", fields: [endedBy], references: [id], onDelete: SetNull)

  leaves         LeaveRequest[]
  adjusts        AttendanceAdjust[]
  inAppMessages  InAppMessage[]

  @@index([status, startTime])
  @@index([startTime])
}

enum LeaveCategory {
  DUTY
  MEETING
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation("LeaveUser", fields: [userId], references: [id], onDelete: Cascade)
  category  LeaveCategory
  reason    String @db.Text
  // 会议请假
  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  // 值班请假：星期+节次
  dutyWeekday Int? // 0-4
  dutyPeriod  Int? // 0-4
  fromTime  DateTime?
  toTime    DateTime?
  status    LeaveStatus  @default(PENDING)
  decidedAt DateTime?
  decidedById String?
  decider   User?        @relation("LeaveDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  rejectReason String?

  messages InAppMessage[]

  @@index([userId, status])
  @@index([meetingId])
  @@index([status])
}

model Announcement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title String
  body  String @db.Text

  /** 是否在用户每日首次进入首页时弹窗展示 */
  popupEnabled Boolean @default(false)
  /** 弹窗持续天数（从创建日算起）；<=0 表示不弹 */
  popupDays    Int     @default(0)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  images   AnnouncementImage[]
  messages InAppMessage[]
  popupShown AnnouncementPopupShown[]

  @@index([createdAt])
  @@index([popupEnabled, createdAt])
}

model AnnouncementImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  url  String
  sort Int @default(0)

  @@index([announcementId, sort])
}

/** 记录“某用户某天是否已弹过某公告”（每日首次进入时幂等） */
model AnnouncementPopupShown {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** YYYY-MM-DD */
  day String

  @@unique([announcementId, userId, day])
  @@index([userId, day])
}

model InAppMessage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  toUserId   String
  toUser     User     @relation(fields: [toUserId], references: [id], onDelete: Cascade)
  type       String   // TASK_DONE, LEAVE_APPLY, LEAVE_DECIDED
  title      String
  body       String @db.Text
  read       Boolean  @default(false)
  /** 公告类消息：指向公告详情页，用于聚合已读统计/图片展示 */
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: SetNull)
  leaveId    String?
  leave      LeaveRequest? @relation(fields: [leaveId], references: [id], onDelete: SetNull)
  /// 会议类消息跳转用（新会议通知、旷会提醒等）
  meetingId  String?
  meeting    Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  /// 任务完成提醒跳转任务详情
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([toUserId, read])
  @@index([createdAt])
  @@index([announcementId])
  @@index([meetingId])
  @@index([taskId])
}

/// 月度考勤加减分（如例会旷会 -1，请假不影响此处）
model AttendanceAdjust {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearMonth  String
  /// 可为负数
  amount     Int
  reason     String @db.Text
  meetingId  String?
  meeting    Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@index([userId, yearMonth])
  @@index([meetingId])
}

model Task {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  title     String
  description String? @db.Text
  /** 整个任务对外的起止时间（多时间段时为各段 min/max 汇总） */
  startTime DateTime
  endTime   DateTime
  points    Int
  headcountHint Int?
  status    TaskStatus @default(OPEN)
  /**
   * 为 true 时该任务不纳入部员月报/考勤（管理人员「提前结束」等）
   * 为 false 时与自动全员确认结束的任务正常计考勤
   */
  excludeFromAttendance Boolean @default(false)
  /** 任务截止满 12 小时仍滞留时，已向干事/管理人员推送过一次站内信的时间（幂等） */
  stallNotifiedAt DateTime?

  publisherId String
  publisher   User       @relation("TaskPublisher", fields: [publisherId], references: [id])

  images      TaskImage[]
  timeSlots   TaskTimeSlot[]
  claims      TaskClaim[]
  submissions   TaskSubmission[]
  inAppMessages   InAppMessage[]

  @@index([startTime, endTime])
  @@index([status])
  @@index([publisherId])
  @@index([stallNotifiedAt])
}

/** 单任务可配置多个进行时间段；列表/接取等仍用 Task.startTime/endTime 汇总边界 */
model TaskTimeSlot {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  /// 本段接取人数上限，null/0=不限制
  headcountHint Int?
  sort      Int      @default(0)

  claims   TaskClaim[]

  @@index([taskId, sort])
}

model TaskImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  url   String
  sort  Int    @default(0)

  @@index([taskId, sort])
}

model TaskClaim {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  claimTime DateTime @default(now())
  status    ClaimStatus @default(CLAIMED)
  /// 多时段任务：接取哪一段（唯一一段）
  timeSlotId String?
  timeSlot   TaskTimeSlot? @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)

  /// 同一用户可接多段：按 (任务, 用户, 时段) 唯一；无时段表时 timeSlotId 可为 null（每用户至多一条，由接口保证）
  @@unique([taskId, userId, timeSlotId])
  @@index([userId, claimTime])
  @@index([taskId, claimTime])
  @@index([timeSlotId])
}

model TaskSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  submitTime DateTime @default(now())
  note       String? @db.Text

  evidenceImages EvidenceImage[]
  review         TaskReview?

  @@unique([taskId, userId])
  @@index([userId, submitTime])
  @@index([taskId, submitTime])
}

model EvidenceImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  submissionId String
  submission   TaskSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  url  String
  sort Int @default(0)

  @@index([submissionId, sort])
}

model TaskReview {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  submissionId String @unique
  submission   TaskSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("TaskReviewer", fields: [reviewerId], references: [id])

  reviewTime DateTime @default(now())
  result     ReviewResult
  reason     String?

  @@index([reviewerId, reviewTime])
  @@index([result])
}

model MonthlyReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  month     String   @unique // YYYY-MM
  generatedAt DateTime @default(now())
  generatedBy String? // userId 或 null(自动)

  statsJson String @db.LongText
  exportPath String?
}
